---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const adOptions = [
  { icon: 'fas fa-image', title: 'ब्यानर विज्ञापन', desc: 'होमपेज र भित्री समाचार पृष्ठहरूमा आकर्षक ब्यानरहरू राख्न सकिन्छ।' },
  { icon: 'fas fa-pencil-alt', title: 'प्रायोजित सामाग्री', desc: 'आफ्नो ब्रान्ड वा उत्पादनको बारेमा समाचारमूलक जानकारी लेख्न सकिन्छ।' },
  { icon: 'fas fa-play-circle', title: 'भिडियो विज्ञापन', desc: 'हाम्रा भिडियो सामग्री र सामाजिक मिडियामा भिडियो विज्ञापन राख्न सकिन्छ।' },
];
---

<Layout title="विज्ञापन - Online Pati News">
  <TopBar />
  <Header />
  <Navbar />
  
  <main class="page-wrapper-premium">
    <div class="container main-container-p">
      <div class="breadcrumbs-p">
        <a href="/"><i class="fas fa-home"></i> गृहपृष्ठ</a> 
        <i class="fas fa-chevron-right sep"></i> 
        <span class="curr">विज्ञापन</span>
      </div>

      <header class="page-hero-premium">
        <h1 class="page-title-p">हामीसँग विज्ञापन दिनुहोस्</h1>
        <p class="page-subtitle-p">आफ्नो व्यवसायलाई लाखौँ पाठकहरूसम्म पुर्‍याउने उत्कृष्ट माध्यम</p>
      </header>

      <div class="opn-layout">
        <div class="main-content-p">
          <div class="premium-static-card">
            <section class="ad-intro-p">
              <h2 class="section-heading-p">हामीसँग किन विज्ञापन दिने?</h2>
              <p>अनलाइन पाटी न्यूज नेपालको एक लोकप्रिय समाचार पोर्टल हो जसले लाखौँ पाठकहरूलाई दैनिक समाचार र सूचनाहरू प्रदान गर्दछ। हाम्रो प्लेटफर्ममा विज्ञापन दिनु भनेको तपाईंको सेवा वा उत्पादनलाई सिधै लक्षित समुदायमा पुर्‍याउनु हो।</p>
            </section>

            <div class="premium-ad-options-grid">
              {adOptions.map((opt) => (
                <div class="p-ad-option-card">
                  <div class="p-icon"><i class={opt.icon}></i></div>
                  <h3>{opt.title}</h3>
                  <p>{opt.desc}</p>
                </div>
              ))}
            </div>

            <section class="ad-contact-section">
              <div class="ad-contact-box">
                <h2 class="section-heading-p">विज्ञापनको लागि सम्पर्क</h2>
                <p>हाम्रो पोर्टलमा विज्ञापन संबन्धी विस्तृत जानकारीको लागि निम्न माध्यमबाट सम्पर्क गर्न सक्नुहुन्छ:</p>
                
                <div class="p-ad-contact-info">
                  <div class="p-ad-item">
                    <i class="fas fa-envelope"></i>
                    <div class="text">
                      <span class="label">इमेल पठाउनुहोस्:</span>
                      <span class="val">advertisement@onlinepatinews.com</span>
                    </div>
                  </div>
                  <div class="p-ad-item">
                    <i class="fas fa-phone-alt"></i>
                    <div class="text">
                      <span class="label">फोन गर्नुहोस्:</span>
                      <span class="val">+९७७-०१-४२०००००, ९८६०८६०८३७</span>
                    </div>
                  </div>
                  <div class="p-ad-item">
                    <i class="fab fa-whatsapp"></i>
                    <div class="text">
                      <span class="label">वाट्सएप / भाइबर:</span>
                      <span class="val">+९७७-९८५१०००००</span>
                    </div>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </div>

        <Sidebar />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Reuse premium patterns from About/Contact */
  .premium-ad-options-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin: 40px 0; }
  .p-ad-option-card { background: var(--bg-gray); padding: 30px 20px; border-radius: 12px; text-align: center; border-top: 4px solid var(--primary-color); transition: 0.3s; }
  .p-ad-option-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-sm); background: #fff; border-color: var(--highlight-color); }
  .p-ad-option-card .p-icon { font-size: 2.5rem; color: var(--primary-color); margin-bottom: 15px; }
  .p-ad-option-card h3 { font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-dark); margin-bottom: 12px; }
  .p-ad-option-card p { font-size: 1rem; color: var(--text-muted); line-height: 1.5; }

  .ad-contact-box { background: #f8fafc; padding: 40px; border-radius: 15px; border: 1px solid var(--border-color); }
  .p-ad-contact-info { display: flex; flex-direction: column; gap: 20px; margin-top: 30px; }
  .p-ad-item { display: flex; align-items: center; gap: 20px; background: #fff; padding: 15px 25px; border-radius: 10px; box-shadow: var(--shadow-sm); border-left: 5px solid var(--highlight-color); }
  .p-ad-item i { font-size: 1.5rem; color: var(--primary-color); }
  .p-ad-item .text { display: flex; flex-direction: column; }
  .p-ad-item .label { font-size: 0.9rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
  .p-ad-item .val { font-size: 1.1rem; color: var(--text-dark); font-weight: 700; }

  @media (max-width: 992px) {
    .premium-ad-options-grid { grid-template-columns: 1fr; }
  }
</style>
