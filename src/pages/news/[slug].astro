---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FacebookFeed from '../../components/FacebookFeed.astro';
import { getWordPressPosts, getWordPressPostBySlug } from '../../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getWordPressPosts(100);
  return posts.map((post) => ({
    params: { slug: post.slug || post.id.toString() },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;

// Secondary fetch if props aren't available (e.g. dynamic routes or server output)
const item = post || await getWordPressPostBySlug(slug as string);

if (!item) {
  return Astro.redirect('/404');
}

const latestNews = await getWordPressPosts(10);
---

<Layout title={`${item.title} - Online Pati News`}>
  <TopBar />
  <Header />
  <Navbar />
  
  <main class="article-page">
    <div class="container breadcrumbs">
      <a href="/">गृहपृष्ठ</a> <i class="fas fa-chevron-right"></i> 
      <a href={`/${item.categorySlug}`}>{item.category}</a> <i class="fas fa-chevron-right"></i>
      <span set:html={item.title}></span>
    </div>

    <div class="container main-sidebar-layout">
      <article class="main-content">
        <header class="article-header">
          <span class="category-badge">{item.category}</span>
          <h1 set:html={item.title}></h1>
          <div class="article-meta">
             <span><i class="far fa-user"></i> {item.author}</span>
             <span><i class="far fa-calendar-alt"></i> {item.date}</span>
             <span><i class="far fa-clock"></i> ३ मिनेट पढ्ने</span>
          </div>
          <div class="social-share">
            <a href="#" class="share-btn fb"><i class="fab fa-facebook-f"></i> फेसबुक</a>
            <a href="#" class="share-btn tw"><i class="fab fa-twitter"></i> ट्विटर</a>
            <a href="#" class="share-btn wa"><i class="fab fa-whatsapp"></i> ह्वाट्सएप</a>
          </div>
        </header>

        <div class="featured-image">
          <img src={item.image} alt={item.title} />
        </div>

        <div class="article-body" set:html={item.content}>
        </div>

        <div class="tags-section">
          <span class="tag">#नेपाल</span>
          <span class="tag">#समाचार</span>
          <span class="tag">#{item.category}</span>
        </div>
      </article>

      <aside class="sidebar">
        <FacebookFeed />
        <div class="sidebar-ad">
           <a href="/advertise" class="ad-link">
             <img src="https://images.unsplash.com/photo-1454165833912-016710398cd2?auto=format&fit=crop&q=80&w=300&h=250" alt="Sidebar Ad" />
           </a>
        </div>
        <div class="trending-sidebar">
          <h3 class="sidebar-title">भर्खरैका समाचार</h3>
          <div class="trending-list">
            {latestNews.filter(n => n.id !== item.id).slice(0, 5).map(news => (
              <a href={`/news/${news.slug || news.id}`} class="trending-item">
                <img src={news.image} alt={news.title} />
                <h4 set:html={news.title}></h4>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>


  <Footer />
</Layout>

<style>
  .article-page {
    background-color: #fcfcfc;
    padding-bottom: 3rem;
  }

  .breadcrumbs {
    padding: 1rem 0;
    font-size: 0.9rem;
    color: #666;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs i {
    font-size: 0.7rem;
    color: #ccc;
  }

  .breadcrumbs a:hover {
    color: var(--primary-color);
  }

  .main-sidebar-layout {
    display: grid;
    grid-template-columns: 2.5fr 1fr;
    gap: 2rem;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .category-badge {
    display: inline-block;
    background-color: var(--primary-color);
    color: white;
    padding: 2px 10px;
    font-family: var(--font-headline);
    font-size: 0.9rem;
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.8rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }

  .article-meta {
    display: flex;
    gap: 2rem;
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .article-meta i {
    margin-right: 0.3rem;
    color: var(--primary-color);
  }

  .social-share {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .share-btn {
    padding: 0.5rem 1.2rem;
    border-radius: 4px;
    color: white;
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .share-btn.fb { background-color: #3b5998; }
  .share-btn.tw { background-color: #1da1f2; }
  .share-btn.wa { background-color: #25d366; }

  .featured-image {
    margin-bottom: 2rem;
    border-radius: 8px;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-body {
    font-size: 1.2rem;
    line-height: 1.8;
    color: #333;
    font-family: var(--font-body);
  }

  .article-body p {
    margin-bottom: 1.5rem;
  }

  .tags-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
    display: flex;
    gap: 0.8rem;
  }

  .tag {
    background-color: #f0f0f0;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #666;
  }

  .sidebar-title {
    font-family: var(--font-headline);
    font-size: 1.4rem;
    border-bottom: 2px solid var(--primary-color);
    display: inline-block;
    padding-bottom: 0.3rem;
    margin-bottom: 1.5rem;
  }

  .trending-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .trending-item {
    display: flex;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .trending-item img {
    width: 80px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .trending-item h4 {
    font-size: 0.95rem;
    line-height: 1.3;
    font-family: var(--font-headline);
  }

  .trending-item:hover h4 {
    color: var(--primary-color);
  }

  @media (max-width: 992px) {
    .main-sidebar-layout {
      grid-template-columns: 1fr;
    }
    h1 {
      font-size: 2rem;
    }
    .article-meta {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
