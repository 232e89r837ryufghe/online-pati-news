---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Navbar from '../../components/Navbar.astro';
import Sidebar from '../../components/Sidebar.astro';
import Footer from '../../components/Footer.astro';
import { getWordPressPosts, getWordPressPostBySlug } from '../../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getWordPressPosts(100);
  return posts.map((post) => ({
    params: { slug: post.slug || post.id.toString() },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;

// Secondary fetch if props aren't available (e.g. dynamic routes or server output)
const item = post || await getWordPressPostBySlug(slug as string);

if (!item) {
  return Astro.redirect('/404');
}
---

<Layout title={`${item.title} - Online Pati News`}>
  <TopBar />
  <Header />
  <Navbar />
  
  <main class="article-page-wrapper">
    <div class="container article-container">
      <div class="breadcrumbs">
        <a href="/"><i class="fas fa-home"></i> गृहपृष्ठ</a> 
        <i class="fas fa-chevron-right sep"></i> 
        <a href={`/${item.categorySlug}`} class="cat-link">{item.category}</a> 
        <i class="fas fa-chevron-right sep"></i>
        <span class="curr" set:html={item.title}></span>
      </div>

      <div class="opn-layout">
        <article class="main-content-article">
          <header class="article-header-premium">
            <span class="category-badge-p">{item.category}</span>
            <h1 class="article-title-p" set:html={item.title}></h1>
            
            <div class="article-meta-p">
              <div class="author-block">
                <div class="author-img">
                  <i class="fas fa-user-circle"></i>
                </div>
                <div class="author-details">
                  <span class="author-name">{item.author}</span>
                  <span class="post-date"><i class="far fa-clock"></i> {item.date}</span>
                </div>
              </div>
              
              <div class="article-actions">
                <button class="action-btn" onclick="window.print()" title="प्रिन्ट गर्नुहोस्"><i class="fas fa-print"></i></button>
                <button class="action-btn share-trigger" title="सेयर गर्नुहोस्"><i class="fas fa-share-alt"></i></button>
              </div>
            </div>

            <div class="premium-social-share">
              <a href="#" class="p-share-btn fb"><i class="fab fa-facebook-f"></i> फेसबुक</a>
              <a href="#" class="p-share-btn tw"><i class="fab fa-twitter"></i> ट्विटर</a>
              <a href="#" class="p-share-btn wa"><i class="fab fa-whatsapp"></i> ह्वाट्सएप</a>
              <a href="#" class="p-share-btn ms"><i class="fab fa-facebook-messenger"></i> म्यासेन्जर</a>
            </div>
          </header>

          <div class="article-featured-image">
            <img src={item.image} alt={item.title} />
            {item.caption && <div class="image-caption">{item.caption}</div>}
          </div>

          <div class="article-content-premium" set:html={item.content}>
          </div>

          <div class="article-footer-tags">
            <div class="tags-label">सम्बन्धित ट्यागहरू:</div>
            <div class="tags-list">
              <span class="p-tag">#नेपाल</span>
              <span class="p-tag">#समाचार</span>
              <span class="p-tag">#{item.category}</span>
              <span class="p-tag">#OnlinePati</span>
            </div>
          </div>
          
          <div class="social-share-bottom">
            <h4>यो समाचार सेयर गर्नुहोस्:</h4>
            <div class="premium-social-share">
              <a href="#" class="p-share-btn fb"><i class="fab fa-facebook-f"></i></a>
              <a href="#" class="p-share-btn tw"><i class="fab fa-twitter"></i></a>
              <a href="#" class="p-share-btn wa"><i class="fab fa-whatsapp"></i></a>
              <a href="#" class="p-share-btn ms"><i class="fab fa-facebook-messenger"></i></a>
              <a href="#" class="p-share-btn copy"><i class="fas fa-link"></i></a>
            </div>
          </div>
        </article>

        <Sidebar />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .article-page-wrapper { background-color: var(--bg-white); padding: 20px 0 60px; }
  
  .breadcrumbs { display: flex; align-items: center; gap: 10px; padding: 10px 0 25px; font-size: 0.95rem; color: var(--text-muted); border-bottom: 1px solid var(--border-color); margin-bottom: 30px; }
  .breadcrumbs a { color: var(--text-light); transition: 0.2s; }
  .breadcrumbs a:hover { color: var(--primary-color); }
  .breadcrumbs .sep { font-size: 0.7rem; opacity: 0.5; }
  .breadcrumbs .curr { color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; }

  /* Premium Article Header */
  .article-header-premium { margin-bottom: 30px; }
  .category-badge-p { display: inline-block; background: var(--highlight-color); color: #fff; padding: 4px 15px; border-radius: 4px; font-family: var(--font-headline); font-size: 1.1rem; margin-bottom: 15px; }
  .article-title-p { font-family: var(--font-headline); font-size: 3.5rem; line-height: 1.15; font-weight: 700; color: var(--text-main); margin-bottom: 25px; }

  .article-meta-p { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); margin-bottom: 25px; }
  .author-block { display: flex; align-items: center; gap: 15px; }
  .author-img { font-size: 2.5rem; color: var(--primary-color); opacity: 0.8; }
  .author-details { display: flex; flex-direction: column; }
  .author-name { font-weight: 700; color: var(--text-dark); font-size: 1.1rem; }
  .post-date { font-size: 0.9rem; color: var(--text-muted); }

  .action-btn { background: var(--bg-gray); border: 1px solid var(--border-color); width: 40px; height: 40px; border-radius: 50%; color: var(--text-light); cursor: pointer; transition: 0.2s; margin-left: 10px; }
  .action-btn:hover { background: var(--primary-color); color: #fff; border-color: var(--primary-color); }

  /* Premium Social Share */
  .premium-social-share { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .p-share-btn { padding: 8px 18px; border-radius: 4px; color: #fff; font-weight: 600; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; transition: 0.3s; }
  .p-share-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0,0,0,0.15); opacity: 0.9; }
  
  .p-share-btn.fb { background: #1877f2; }
  .p-share-btn.tw { background: #1da1f2; }
  .p-share-btn.wa { background: #25d366; }
  .p-share-btn.ms { background: #0084ff; }
  .p-share-btn.copy { background: #64748b; }

  /* Image & Content */
  .article-featured-image { margin-bottom: 35px; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); }
  .article-featured-image img { width: 100%; height: auto; display: block; }
  .image-caption { background: var(--bg-gray); padding: 10px 15px; font-size: 0.9rem; color: var(--text-light); text-align: center; border-bottom: 3px solid var(--primary-color); }

  .article-content-premium { font-family: var(--font-body); font-size: 1.3rem; line-height: 1.85; color: var(--text-dark); }
  .article-content-premium p { margin-bottom: 1.8rem; }
  .article-content-premium h2, .article-content-premium h3 { font-family: var(--font-headline); margin: 30px 0 20px; color: var(--text-main); }
  .article-content-premium img { border-radius: 8px; margin: 20px 0; }
  .article-content-premium blockquote { border-left: 5px solid var(--primary-color); background: var(--bg-gray); padding: 25px 30px; margin: 30px 0; font-style: italic; font-size: 1.4rem; color: var(--primary-dark); }

  /* Tags & Bottom Share */
  .article-footer-tags { margin-top: 50px; padding-top: 30px; border-top: 1px solid var(--border-color); }
  .tags-label { font-weight: 700; margin-bottom: 15px; color: var(--text-main); }
  .tags-list { display: flex; gap: 10px; flex-wrap: wrap; }
  .p-tag { background: var(--bg-gray); padding: 6px 15px; border-radius: 30px; font-size: 0.9rem; color: var(--text-light); border: 1px solid var(--border-color); transition: 0.2s; }
  .p-tag:hover { border-color: var(--primary-color); color: var(--primary-color); background: #fff; }

  .social-share-bottom { background: var(--bg-gray); padding: 30px; border-radius: var(--radius); margin-top: 40px; text-align: center; }
  .social-share-bottom h4 { font-family: var(--font-headline); font-size: 1.5rem; margin-bottom: 20px; }
  .social-share-bottom .premium-social-share { justify-content: center; }

  @media (max-width: 768px) {
    .article-title-p { font-size: 2.2rem; }
    .breadcrumbs .curr { display: none; }
    .article-meta-p { flex-direction: column; align-items: flex-start; gap: 15px; }
    .article-actions { width: 100%; justify-content: flex-end; display: flex; }
    .article-content-premium { font-size: 1.15rem; }
  }
</style>
