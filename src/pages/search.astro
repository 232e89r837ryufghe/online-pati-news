---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { searchPosts } from "../lib/cms";

const query = Astro.url.searchParams.get("q") || "";
const results = query ? await searchPosts(query) : [];
import { getRelativeTimeNepali } from '../utils/date';
---

<Layout title={`खोज नतिजा: ${query} - Online Pati News`}>
  <TopBar />
  <Navbar />
  
  <main class="search-page-wrapper">
    <div class="container search-container-p">
      <div class="breadcrumbs">
        <a href="/"><i class="bi bi-house"></i> गृहपृष्ठ</a> 
        <i class="bi bi-chevron-right sep"></i> 
        <span class="curr">खोज नतिजा</span>
      </div>

      <header class="search-hero-p">
        <h1 class="search-title-p">खोज नतिजा: "{query}"</h1>
        <div class="search-form-p">
          <form action="/search" method="GET" class="premium-search-bar">
            <input type="text" name="q" value={query} placeholder="समाचार खोज्नुहोस्..." required />
            <button type="submit"><i class="bi bi-search"></i></button>
          </form>
        </div>
        <p class="search-stats-p">तपाईंको खोजीका लागि <strong>{results.length}</strong> समाचार सामग्री फेला परेका छन्।</p>
      </header>

      <div class="opn-layout">
        <div class="opn-main-column">
          {results.length > 0 ? (
            <div class="premium-search-list">
              {results.map((item) => (
                <article class="search-result-card-p">
                  <a href={`/news/${item.slug || item.id}`} class="search-card-inner-p">
                    <div class="search-card-image-p">
                      <img src={item.image} alt={item.title} />
                      <div class="search-cat-tag-p">{item.category}</div>
                    </div>
                    <div class="search-card-content-p">
                      <h2 class="search-card-title-p" set:html={item.title}></h2>
                      <p class="search-card-excerpt-p" set:html={item.excerpt}></p>
                      <div class="search-card-footer-p">
                        <span class="search-meta-p">
                          <img src="/logo.png" alt="Logo" class="mini-logo" /> 
                          {item.author || 'Online Pati News'}
                        </span>
                        <span class="search-meta-p"><i class="bi bi-clock"></i> {getRelativeTimeNepali(item.dateIso || '')}</span>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-no-results">
              <div class="no-res-icon"><i class="bi bi-search"></i></div>
              <h3>केही फेला परेन</h3>
              <p>माफ गर्नुहोस्, तपाईंको खोजी शब्द "{query}" सँग मिल्दोजुल्दो कुनै सामग्री फेला परेन। कृपया अर्को शब्द प्रयोग गर्नुहोस्।</p>
              <a href="/" class="p-btn-back">मुख्य पृष्ठमा जानुहोस्</a>
            </div>
          )}
        </div>

        <Sidebar />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .search-page-wrapper { background-color: var(--bg-white); padding: 20px 0 60px; }
  
  .search-hero-p { background: #fff; padding: 40px; border-radius: var(--radius); border: 1px solid var(--border-color); margin-bottom: 40px; text-align: center; box-shadow: var(--shadow-sm); }
  .search-title-p { font-family: var(--font-headline); font-size: 2.5rem; color: var(--text-dark); margin-bottom: 25px; }

  .premium-search-bar { display: flex; max-width: 600px; margin: 0 auto 20px; border: 2px solid var(--border-color); border-radius: 40px; overflow: hidden; background: #fff; transition: 0.3s; }
  .premium-search-bar:focus-within { border-color: var(--primary-color); box-shadow: 0 0 0 4px rgba(64, 119, 202, 0.1); }
  .premium-search-bar input { flex: 1; border: none; padding: 12px 25px; font-size: 1.1rem; outline: none; background: transparent; }
  .premium-search-bar button { background: var(--primary-color); color: #fff; border: none; padding: 0 25px; border-radius: 0 40px 40px 0; font-size: 1.2rem; cursor: pointer; transition: 0.2s; }
  .premium-search-bar button:hover { background: var(--primary-dark); }
  
  .search-stats-p { font-size: 1.05rem; color: var(--text-muted); }
  .search-stats-p strong { color: var(--highlight-color); }

  /* Premium Search List */
  .premium-search-list { display: flex; flex-direction: column; gap: 30px; }
  
  .search-result-card-p { background: #fff; border-radius: var(--radius); border: 1px solid var(--border-color); overflow: hidden; transition: 0.3s; box-shadow: var(--shadow-sm); }
  .search-result-card-p:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
  
  .search-card-inner-p { display: grid; grid-template-columns: 280px 1fr; text-decoration: none; color: inherit; }
  
  .search-card-image-p { position: relative; height: 100%; overflow: hidden; }
  .search-card-image-p img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
  .search-result-card-p:hover .search-card-image-p img { transform: scale(1.05); }
  
  .search-cat-tag-p { position: absolute; top: 15px; left: 15px; background: var(--primary-color); color: #fff; padding: 3px 12px; border-radius: 4px; font-size: 0.85rem; font-family: var(--font-headline); z-index: 2; }

  .search-card-content-p { padding: 25px; display: flex; flex-direction: column; }
  .search-card-title-p { font-family: var(--font-headline); font-size: 1.8rem; line-height: 1.25; color: var(--text-main); margin-bottom: 15px; transition: 0.2s; }
  .search-result-card-p:hover .search-card-title-p { color: var(--primary-color); }
  
  .search-card-excerpt-p { font-size: 1.1rem; line-height: 1.6; color: var(--text-light); margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  
  .search-card-footer-p { margin-top: auto; padding-top: 15px; border-top: 1px solid var(--border-color); display: flex; gap: 20px; font-size: 0.9rem; color: var(--text-muted); }
  .search-meta-p i { color: var(--highlight-color); margin-right: 5px; }

  @media (max-width: 992px) {
    .search-card-inner-p { grid-template-columns: 220px 1fr; }
    .search-hero-p { padding: 30px 20px; }
  }
  @media (max-width: 768px) {
    .search-card-inner-p { grid-template-columns: 1fr; }
    .search-card-image-p { height: 200px; }
    .search-title-p { font-size: 2rem; }
  }
</style>
