---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="गोपनीयता नीति - Online Pati News">
  <TopBar />
  <Navbar />
  
  <main class="page-wrapper-premium">
    <div class="container main-container-p">
      <div class="breadcrumbs-p">
        <a href="/"><i class="fas fa-home"></i> गृहपृष्ठ</a> 
        <i class="fas fa-chevron-right sep"></i> 
        <span class="curr">गोपनीयता नीति</span>
      </div>

      <header class="page-hero-premium secondary">
        <h1 class="page-title-p">गोपनीयता नीति</h1>
        <p class="page-subtitle-p">तपाईंको गोपनीयता र व्यक्तिगत डेटा सुरक्षाको बारेमा जानकारी</p>
      </header>

      <div class="premium-static-card-centered">
        <div class="p-article-content">
          <p class="lead-text-p">अनलाइन पाटी न्यूज आफ्ना पाठकहरूको गोपनीयताको कदर गर्दछ। यो गोपनीयता नीतिले हामी कसरी तपाईंको जानकारी संकलन, प्रयोग र सुरक्षा गर्छौँ भन्ने बारे जानकारी दिन्छ।</p>
          
          <h2 class="p-section-h">१. संकलन गरिने जानकारी</h2>
          <p>हामीले तपाईंको नाम, इमेल ठेगाना र ब्राउजिङ व्यवहार जस्ता जानकारीहरू सेवा सुधारका लागि संकलन गर्न सक्छौँ।</p>

          <h2 class="p-section-h">२. जानकारीको प्रयोग</h2>
          <p>संकलन गरिएको जानकारी तपाईंलाई अझ राम्रो समाचार अनुभव प्रदान गर्न, विज्ञापनहरू देखाउन र हाम्रा सेवाहरूको विश्लेषण गर्न प्रयोग गरिन्छ।</p>

          <h2 class="p-section-h">३. कुकीज (Cookies)</h2>
          <p>हाम्रो वेबसाइटले प्रयोगकर्ताको अनुभव सुधार गर्न कुकीजको प्रयोग गर्दछ। तपाईंले आफ्नो ब्राउजर सेटिङबाट कुकीजलाई बन्द गर्न सक्नुहुन्छ।</p>

          <h2 class="p-section-h">४. तेस्रो पक्ष लिङ्कहरू</h2>
          <p>हाम्रो वेबसाइटमा अन्य तेस्रो पक्ष वेबसाइटका लिङ्कहरू हुन सक्छन्। ती वेबसाइटहरूको गोपनीयता नीतिको लागि हामी जिम्मेवार छैनौँ।</p>

          <div class="p-last-updated">अन्तिम पटक अद्यावधिक गरिएको: २०२४/०४/०८</div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Reuse patterns and add centered variant */
  .premium-static-card-centered { 
    background: #fff; padding: 60px 80px; border-radius: var(--radius); border: 1px solid var(--border-color); 
    box-shadow: var(--shadow-sm); max-width: 1000px; margin: 0 auto;
  }
  
  .lead-text-p { font-size: 1.4rem; line-height: 1.7; color: var(--text-dark); font-weight: 500; margin-bottom: 40px; padding-bottom: 30px; border-bottom: 2px solid var(--border-color); }
  
  .p-section-h { font-family: var(--font-headline); font-size: 1.8rem; color: var(--text-main); margin: 40px 0 20px; }
  .p-article-content p { font-size: 1.2rem; line-height: 1.8; color: var(--text-light); margin-bottom: 20px; }
  
  .p-last-updated { margin-top: 60px; font-size: 0.9rem; color: var(--text-muted); font-style: italic; border-top: 1px solid var(--border-color); padding-top: 20px; text-align: right; }

  @media (max-width: 768px) {
    .premium-static-card-centered { padding: 40px 25px; }
    .lead-text-p { font-size: 1.2rem; }
  }
</style>
