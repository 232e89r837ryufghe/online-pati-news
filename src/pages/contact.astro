---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const contactInfo = [
  { icon: 'fas fa-map-marker-alt', title: 'ठेगाना', content: 'पुतलीसडक, काठमाडौँ, नेपाल' },
  { icon: 'fas fa-phone-alt', title: 'फोन नम्बर', content: '+९७७-०१-४२०००००, ९८६०८६०८३७' },
  { icon: 'fas fa-envelope', title: 'इमेल', content: 'info@onlinepatinews.com' },
];
---

<Layout title="सम्पर्क - Online Pati News">
  <TopBar />
  <Navbar />
  
  <main class="page-wrapper-premium">
    <div class="container main-container-p">
      <div class="breadcrumbs-p">
        <a href="/"><i class="fas fa-home"></i> गृहपृष्ठ</a> 
        <i class="fas fa-chevron-right sep"></i> 
        <span class="curr">सम्पर्क</span>
      </div>

      <header class="page-hero-premium">
        <h1 class="page-title-p">सम्पर्क गर्नुहोस्</h1>
        <p class="page-subtitle-p">हामीलाई कुनै सुझाव, प्रतिक्रिया वा समाचार पठाउन सम्पर्क गर्नुहोस्।</p>
      </header>

      <div class="opn-layout">
        <div class="main-content-p">
          <div class="premium-static-card">
            <div class="contact-info-strip-p">
              {contactInfo.map((info) => (
                <div class="p-info-card">
                  <div class="p-icon"><i class={info.icon}></i></div>
                  <h3>{info.title}</h3>
                  <p>{info.content}</p>
                </div>
              ))}
            </div>

            <div class="contact-form-layout-p">
              <div class="contact-form-side">
                <h2 class="section-heading-p">सन्देश पठाउनुहोस्</h2>
                <p class="form-intro">तलको फारम भर्नुहोस् र हाम्रो टोलीले तपाईंलाई छिट्टै सम्पर्क गर्नेछ।</p>
                
                <form class="premium-contact-form">
                  <div class="p-form-row">
                    <div class="p-form-group">
                      <label><i class="far fa-user"></i> पूरा नाम</label>
                      <input type="text" placeholder="जस्तै: राम बहादुर" required />
                    </div>
                    <div class="p-form-group">
                      <label><i class="far fa-envelope"></i> इमेल</label>
                      <input type="email" placeholder="email@example.com" required />
                    </div>
                  </div>
                  
                  <div class="p-form-group">
                    <label><i class="far fa-bookmark"></i> विषय</label>
                    <input type="text" placeholder="सम्पर्कको उद्देश्य" required />
                  </div>
                  
                  <div class="p-form-group">
                    <label><i class="far fa-comment-dots"></i> सन्देश</label>
                    <textarea rows="6" placeholder="तपाईंको सन्देश यहाँ लेख्नुहोस्..." required></textarea>
                  </div>
                  
                  <button type="submit" class="p-submit-btn">
                    <span>सन्देश पठाउनुहोस्</span>
                    <i class="fas fa-paper-plane"></i>
                  </button>
                </form>
              </div>
            </div>

            <div class="premium-map-p">
              <div class="map-placeholder-p">
                <i class="fas fa-map-marked-alt"></i>
                <h3>गुगल म्याप</h3>
                <p>यहाँ कार्यालयको लोकेसन लोड हुनेछ</p>
              </div>
            </div>
          </div>
        </div>

        <aside class="sidebar-p">
          <div class="p-sidebar-widget">
            <h3 class="w-title"><i class="far fa-clock"></i> कार्यालय समय</h3>
            <div class="w-content">
              <div class="time-row"><span>आइतबार - शुक्रबार:</span> <strong>१०:०० - ५:००</strong></div>
              <div class="time-row"><span>शनिबार:</span> <strong>बन्द</strong></div>
            </div>
          </div>
          
          <div class="p-sidebar-widget ad-widget">
            <h3 class="w-title"><i class="fas fa-ad"></i> विज्ञापनको लागि</h3>
            <div class="w-content">
              <p>हाम्रो पोर्टलमा विज्ञापन संबन्धी जानकारीको लागि तलको नम्बरमा कल गर्नुहोस्:</p>
              <div class="ad-phone">९८६०८६०८३७</div>
            </div>
          </div>
          
          <Sidebar />
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Reuse premium patterns from About */
  .contact-info-strip-p { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 50px; }
  .p-info-card { background: var(--bg-gray); padding: 30px 20px; border-radius: 12px; text-align: center; border-bottom: 4px solid var(--primary-color); transition: 0.3s; }
  .p-info-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-sm); }
  .p-info-card .p-icon { font-size: 2rem; color: var(--primary-color); margin-bottom: 15px; }
  .p-info-card h3 { font-family: var(--font-headline); font-size: 1.4rem; color: var(--text-dark); margin-bottom: 8px; }
  .p-info-card p { font-size: 1rem; color: var(--text-muted); line-height: 1.4; }

  /* Premium Form */
  .contact-form-layout-p { margin-bottom: 50px; }
  .form-intro { font-size: 1.1rem; color: var(--text-light); margin-bottom: 30px; }
  
  .premium-contact-form { display: flex; flex-direction: column; gap: 25px; }
  .p-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
  .p-form-group { display: flex; flex-direction: column; gap: 10px; }
  .p-form-group label { font-family: var(--font-headline); font-size: 1.1rem; color: var(--text-dark); display: flex; align-items: center; gap: 8px; }
  .p-form-group label i { color: var(--primary-color); }
  
  .p-form-group input, .p-form-group textarea { 
    padding: 15px 20px; border: 2px solid var(--border-color); border-radius: 10px; 
    font-family: var(--font-body); font-size: 1rem; outline: none; transition: 0.3s; background: #fff;
  }
  .p-form-group input:focus, .p-form-group textarea:focus { border-color: var(--primary-color); box-shadow: 0 0 0 4px rgba(64, 119, 202, 0.1); }

  .p-submit-btn { 
    align-self: flex-start; background: var(--primary-color); color: #fff; border: none; 
    padding: 15px 40px; border-radius: 10px; font-family: var(--font-headline); font-size: 1.3rem;
    font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 12px; transition: 0.3s;
  }
  .p-submit-btn:hover { background: var(--primary-dark); transform: scale(1.02); box-shadow: var(--shadow-md); }

  .premium-map-p { height: 400px; border-radius: 15px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); }
  .map-placeholder-p { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f1f5f9; color: #94a3b8; }
  .map-placeholder-p i { font-size: 4rem; margin-bottom: 15px; }

  /* Contact Sidebar Widgets */
  .p-sidebar-widget { background: #fff; border: 1px solid var(--border-color); border-radius: var(--radius); padding: 25px; margin-bottom: 25px; box-shadow: var(--shadow-sm); }
  .p-sidebar-widget .w-title { font-family: var(--font-headline); font-size: 1.4rem; color: var(--text-main); border-bottom: 2px solid var(--primary-color); padding-bottom: 10px; margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }
  .p-sidebar-widget .w-title i { color: var(--highlight-color); }
  
  .w-content { font-size: 1rem; color: var(--text-light); line-height: 1.8; }
  .time-row { display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border-color); padding: 5px 0; }
  .ad-widget { background: var(--primary-color); color: #fff; border: none; }
  .ad-widget .w-title { color: #fff; border-color: rgba(255,255,255,0.3); }
  .ad-widget .w-title i { color: #fff; }
  .ad-widget .w-content { color: rgba(255,255,255,0.9); }
  .ad-phone { font-family: var(--font-headline); font-size: 2rem; font-weight: 700; color: #fff; margin-top: 10px; text-align: center; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 8px; }

  @media (max-width: 992px) {
    .contact-info-strip-p { grid-template-columns: 1fr; }
    .p-form-row { grid-template-columns: 1fr; }
    .p-submit-btn { width: 100%; justify-content: center; }
  }
</style>
