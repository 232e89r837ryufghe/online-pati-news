---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Navbar from "../components/Navbar.astro";
import BreakingNews from "../components/BreakingNews.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import {
    getPosts,
    getPostsByCategorySlug,
} from "../lib/cms";
import { getAdsByPosition } from "../lib/ads";

// FETCH ADS
const homeTopAds = await getAdsByPosition("home_top");
const homeMidAds = await getAdsByPosition("home_mid");
const homeBottomAds = await getAdsByPosition("home_bottom");

const topAd = homeTopAds[0];
const midAd = homeMidAds[0];
const bottomAd = homeBottomAds[0];

// FETCH DATA
const allPosts = await getPosts(12);
const mainLeads = allPosts.slice(0, 3);
const trendingPosts = allPosts.slice(3, 7);
const textListNews = allPosts.slice(7, 10);
const subGridNews = allPosts.slice(10, 12);

// Categories for specific blocks
const politicsPosts = await getPostsByCategorySlug("राजनीति", 3);
const economyPosts = await getPostsByCategorySlug("अर्थतन्त्र", 4);
const corporatePosts = await getPostsByCategorySlug("कर्पोरेट", 3);
const businessPosts = await getPostsByCategorySlug("बिजनेस", 3);
const healthPosts = await getPostsByCategorySlug("स्वास्थ्य", 3);
const itPosts = await getPostsByCategorySlug("सूचना-प्रविधि", 3);
const sportsPosts = await getPostsByCategorySlug("खेलकुद", 3);
const entertainmentPosts = await getPostsByCategorySlug("मनोरञ्जन", 3);
const opinionPosts = await getPostsByCategorySlug("विचार", 3);

// Province (Default: Koshi)
const provincePosts = await getPostsByCategorySlug("प्रदेश", 4);

// Multimedia (Dark Section)
const multimediaPosts = await getPostsByCategorySlug("मल्टिमिडिया", 3);
const mmMain = multimediaPosts[0] || allPosts[0];
const mmSide = multimediaPosts.slice(1, 4);

// Cover Story (cinematic block)
const coverStories = await getPostsByCategorySlug("कभर", 1);
const coverStory = coverStories[0] || allPosts[5];
---

<Layout title="Online Pati News - Complete Digital Newspaper">
    <TopBar />
    <Navbar />

    <div class="container">
        <div class="ad-container">
            <span class="ad-label">Advertisement</span>
            <a href={topAd?.link_url || "/advertise"} class="ad-slot ad-970x90">
                    <img
                        src={topAd?.image_url || "/logo.png"}
                        alt={topAd?.title || "Real Estate Ad"}
                    />
            </a>
        </div>
    </div>

    <main>
        <BreakingNews />

        <div class="main-wrapper">
            <div class="container">
                <!-- LEAD STORIES STACK (1 + 1 + 1) -->
                <div class="lead-stories-wrapper">
                    {
                        mainLeads.map((post) => (
                            <div class="main-lead">
                                <a href={`/news/${post.slug || post.id}`}>
                                    <h1
                                        class="opn-lead-title"
                                        set:html={post.title}
                                    />
                                </a>
                                <div class="opn-meta">
                                    <span>
                                        <i class="far fa-user" /> {post.author}
                                    </span>
                                    <span>
                                        <i class="far fa-clock" /> {post.date}
                                    </span>
                                </div>
                                {post.image && post.show_image === true && (
                                    <a href={`/news/${post.slug || post.id}`}>
                                        <div class="opn-lead-image">
                                            <img
                                                src={post.image}
                                                alt={post.title}
                                            />
                                        </div>
                                    </a>
                                )}
                                <p
                                    class="opn-lead-excerpt"
                                    set:html={post.excerpt}
                                />
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- TRENDING GRID -->
            <div class="container">
                <div
                    class="sec-header"
                    style="border-top: 3px solid var(--border-color); padding-top:30px;"
                >
                    <h2
                        class="sec-title"
                        style="color: var(--highlight-color); border-bottom-color: var(--highlight-color);"
                    >
                        <i class="fas fa-fire"></i> ट्रेन्डिङ
                    </h2>
                    <a href="/trending" class="sec-link"
                        >सबै ट्रेन्डिङ <i class="fas fa-arrow-right"></i></a
                    >
                </div>
                <div class="trending-grid">
                    {
                        trendingPosts.map((post, index) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="trending-card"
                            >
                                <div class="img-wrap">
                                    <span class="trending-num">
                                        {index + 1}
                                    </span>
                                    {post.image && <img src={post.image} alt={post.title} />}
                                </div>
                                <h3 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- MAIN COLUMN + SIDEBAR -->
            <div class="container opn-layout">
                <div class="opn-main-column">
                    <!-- Text Highlighting -->
                    <ul class="opn-text-list">
                        {
                            textListNews.map((post) => (
                                <li>
                                    <i class="fas fa-square" />
                                    <a
                                        href={`/news/${post.slug || post.id}`}
                                        set:html={post.title}
                                    />
                                </li>
                            ))
                        }
                    </ul>

                    <!-- Sub Grid -->
                    <div class="opn-sub-grid">
                        {
                            subGridNews.map((post) => (
                                <article class="news-card-standard">
                                    <a href={`/news/${post.slug || post.id}`}>
                                    {post.image && (
                                        <div class="img-wrap">
                                            <img
                                                src={post.image}
                                                alt={post.title}
                                            />
                                        </div>
                                    )}
                                        <h3 set:html={post.title} />
                                        <p set:html={post.excerpt} />
                                    </a>
                                </article>
                            ))
                        }
                    </div>
                </div>

                <Sidebar />
            </div>
        </div>

        <div class="container">
            <div class="ad-container">
                <span class="ad-label">Advertisement</span>
                <a href={midAd?.link_url || "/advertise"} class="ad-slot ad-970x250">
                    <img
                        src={midAd?.image_url || "/logo.png"}
                        alt={midAd?.title || "Auto Ad Banner"}
                    />
                </a>
            </div>
        </div>

        <!-- COVER STORY SECTION -->
        {
            coverStory && (
                <section class="cover-story-section">
                    <div class="container">
                        <a
                            href={`/news/${coverStory.slug || coverStory.id}`}
                            class="cover-story-card"
                        >
                            <img
                                src={coverStory.image}
                                alt={coverStory.title}
                                class="cover-story-bg"
                            />
                            <div class="cover-story-overlay">
                                <span class="cover-badge">
                                    <i class="fas fa-star" /> कभर स्टोरी
                                </span>
                                <h2
                                    class="cover-title"
                                    set:html={coverStory.title}
                                />
                                <p
                                    class="cover-excerpt"
                                    set:html={coverStory.excerpt}
                                />
                            </div>
                        </a>
                    </div>
                </section>
            )
        }

        <!-- PROVINCE SECTION -->
        <section class="province-section">
            <div class="container">
                <div class="sec-header">
                    <h2 class="sec-title">प्रदेश समाचार</h2>
                    <a href="/प्रदेश" class="sec-link"
                        >सबै प्रदेश <i class="fas fa-arrow-right"></i></a
                    >
                </div>

                <div class="province-tabs">
                    <button class="prov-btn active" onclick="activateProv(this)"
                        >कोशी</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >मधेश</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >बागमती</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >गण्डकी</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >लुम्बिनी</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >कर्णाली</button
                    >
                    <button class="prov-btn" onclick="activateProv(this)"
                        >सुदूरपश्चिम</button
                    >
                </div>

                <div class="grid-4-col">
                    {
                        provincePosts.map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="prov-card"
                            >
                                {post.image && (
                                    <div class="img-wrap">
                                        <img src={post.image} alt={post.title} />
                                    </div>
                                )}
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- MIXED CATEGORIES -->
        <div class="container category-section">
            <div class="sec-header">
                <h2 class="sec-title">अर्थतन्त्र (Economy)</h2>
                <a href="/अर्थतन्त्र" class="sec-link"
                    >सबै हेर्नुहोस् <i class="fas fa-arrow-right"></i></a
                >
            </div>
            <div class="grid-4-col">
                {
                    economyPosts.map((post) => (
                        <a
                            href={`/news/${post.slug || post.id}`}
                            class="news-card-standard"
                        >
                            {post.image && (
                                <div class="img-wrap">
                                    <img src={post.image} alt={post.title} />
                                </div>
                            )}
                            <h3 set:html={post.title} />
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="container mixed-category-grid">
            <div class="mixed-block">
                <div class="sec-header">
                    <h2
                        class="sec-title"
                        style="color:#0f766e; border-bottom-color:#0f766e;"
                    >
                        कर्पोरेट
                    </h2>
                    <a href="/कर्पोरेट" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    corporatePosts[0] && (
                        <a
                            href={`/news/${corporatePosts[0].slug || corporatePosts[0].id}`}
                            class="lead-card"
                        >
                            {corporatePosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={corporatePosts[0].image}
                                        alt={corporatePosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={corporatePosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        corporatePosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i
                                    class="fas fa-building"
                                    style="color:#0f766e;"
                                />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="mixed-block">
                <div class="sec-header">
                    <h2
                        class="sec-title"
                        style="color:#b45309; border-bottom-color:#b45309;"
                    >
                        बिजनेस
                    </h2>
                    <a href="/बिजनेस" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    businessPosts[0] && (
                        <a
                            href={`/news/${businessPosts[0].slug || businessPosts[0].id}`}
                            class="lead-card"
                        >
                            {businessPosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={businessPosts[0].image}
                                        alt={businessPosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={businessPosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        businessPosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i
                                    class="fas fa-briefcase"
                                    style="color:#b45309;"
                                />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- MORE CATEGORIES -->
        <div class="container mixed-category-grid">
            <div class="mixed-block">
                <div class="sec-header">
                    <h2
                        class="sec-title"
                        style="color:#16a34a; border-bottom-color:#16a34a;"
                    >
                        स्वास्थ्य
                    </h2>
                    <a href="/स्वास्थ्य" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    healthPosts[0] && (
                        <a
                            href={`/news/${healthPosts[0].slug || healthPosts[0].id}`}
                            class="lead-card"
                        >
                            {healthPosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={healthPosts[0].image}
                                        alt={healthPosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={healthPosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        healthPosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i
                                    class="fas fa-heartbeat"
                                    style="color:#16a34a;"
                                />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="mixed-block">
                <div class="sec-header">
                    <h2
                        class="sec-title"
                        style="color:#6366f1; border-bottom-color:#6366f1;"
                    >
                        सूचना-प्रविधि
                    </h2>
                    <a href="/सूचना-प्रविधि" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    itPosts[0] && (
                        <a
                            href={`/news/${itPosts[0].slug || itPosts[0].id}`}
                            class="lead-card"
                        >
                            {itPosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={itPosts[0].image}
                                        alt={itPosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={itPosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        itPosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i
                                    class="fas fa-laptop-code"
                                    style="color:#6366f1;"
                                />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- OPINION -->
        <section class="opinion-section">
            <div class="container">
                <div class="sec-header" style="border-bottom:none;">
                    <h2
                        class="sec-title"
                        style="border-bottom-color: var(--highlight-color); color: var(--text-main);"
                    >
                        विचार / ब्लग
                    </h2>
                    <a href="/विचार" class="sec-link"
                        >थप लेखहरू <i class="fas fa-arrow-right"></i></a
                    >
                </div>
                <div class="opinion-grid">
                    {
                        opinionPosts.map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="opinion-card"
                            >
                                <i class="fas fa-quote-left" />
                                {post.image && (
                                    <div class="opinion-img">
                                        <img src={post.image} alt={post.author} />
                                    </div>
                                )}
                                <span class="opinion-author">
                                    {post.author}
                                </span>
                                <h3
                                    class="opinion-title"
                                    set:html={post.title}
                                />
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- SPORTS & ENT -->
        <div class="container mixed-category-grid">
            <div class="mixed-block">
                <div class="sec-header">
                    <h2 class="sec-title">खेलकुद</h2>
                    <a href="/खेलकुद" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    sportsPosts[0] && (
                        <a
                            href={`/news/${sportsPosts[0].slug || sportsPosts[0].id}`}
                            class="lead-card"
                        >
                            {sportsPosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={sportsPosts[0].image}
                                        alt={sportsPosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={sportsPosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        sportsPosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i
                                    class="fas fa-futbol"
                                    style="color:var(--highlight-color);"
                                />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>

            <div class="mixed-block">
                <div class="sec-header">
                    <h2
                        class="sec-title"
                        style="color:#e91e63; border-bottom-color:#e91e63;"
                    >
                        मनोरञ्जन
                    </h2>
                    <a href="/मनोरञ्जन" class="sec-link">सबै हेर्नुहोस्</a>
                </div>
                {
                    entertainmentPosts[0] && (
                        <a
                            href={`/news/${entertainmentPosts[0].slug || entertainmentPosts[0].id}`}
                            class="lead-card"
                        >
                            {entertainmentPosts[0].image && (
                                <div class="img-wrap">
                                    <img
                                        src={entertainmentPosts[0].image}
                                        alt={entertainmentPosts[0].title}
                                    />
                                </div>
                            )}
                            <h3 set:html={entertainmentPosts[0].title} />
                        </a>
                    )
                }
                <div class="list-group">
                    {
                        entertainmentPosts.slice(1, 3).map((post) => (
                            <a
                                href={`/news/${post.slug || post.id}`}
                                class="list-item"
                            >
                                <i class="fas fa-film" style="color:#e91e63;" />
                                <h4 set:html={post.title} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- MULTIMEDIA -->
        <section class="multimedia-section">
            <div class="container">
                <div class="sec-header">
                    <h2 class="sec-title">फोटो फिचर / भिडियो</h2>
                    <a href="/multimedia" class="sec-link" style="color:#fff;"
                        >सबै हेर्नुहोस् <i class="fas fa-arrow-right"></i></a
                    >
                </div>
                <div class="multimedia-grid">
                    <a
                        href={`/news/${mmMain.slug || mmMain.id}`}
                        class="mm-main"
                    >
                        {mmMain.image && <img src={mmMain.image} alt={mmMain.title} />}
                        <i class="fas fa-play-circle mm-icon"></i>
                        <div class="mm-overlay">
                            <h3 set:html={mmMain.title} />
                        </div>
                    </a>
                    <div class="mm-side-list">
                        {
                            mmSide.map((news) => (
                                <a
                                    href={`/news/${news.slug || news.id}`}
                                    class="mm-side-card"
                                >
                                    {news.image && (
                                        <div class="img-wrap">
                                            <img
                                                src={news.image}
                                                alt={news.title}
                                            />
                                            <i class="fas fa-camera small-icon" />
                                        </div>
                                    )}
                                    <h4 set:html={news.title} />
                                </a>
                            ))
                        }

                        <div
                            class="ad-container"
                            style="margin-top: 15px; padding:0;"
                        >
                            <span class="ad-label" style="color:#888;"
                                >Advertisement</span
                            >
                            <a
                                href="/advertise"
                                class="ad-slot ad-300x250"
                                style="border:none;"
                            >
                                <img
                                    src="/logo.png"
                                    alt="Entertainment Ad"
                                />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="container">
            <div class="ad-container">
                <span class="ad-label">Advertisement</span>
                <a href={bottomAd?.link_url || "/advertise"} class="ad-slot ad-728x90">
                    <img
                        src={bottomAd?.image_url || "/logo.png"}
                        alt={bottomAd?.title || "Ecommerce Ad"}
                    />
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<style is:global>
    main {
        background-color: var(--bg-body);
    }
    .main-wrapper {
        background: var(--bg-white);
        padding: 40px 0;
        box-shadow: var(--shadow-sm);
        margin-bottom: 40px;
    }

    /* LEAD STORIES STACK */
    .lead-stories-wrapper {
        margin-bottom: 40px;
    }
    .main-lead {
        text-align: center;
        margin-bottom: 50px;
        padding-bottom: 50px;
        border-bottom: 2px dashed var(--border-color);
    }
    .main-lead:last-child {
        margin-bottom: 0;
        padding-bottom: 40px;
        border-bottom: none;
    }
    .main-lead .opn-lead-title {
        font-family: var(--font-headline);
        font-size: 3.8rem;
        font-weight: 700;
        line-height: 1.15;
        color: var(--text-main);
        margin-bottom: 15px;
        transition: color 0.3s;
    }
    .main-lead .opn-lead-title:hover {
        color: var(--primary-color);
    }
    .main-lead .opn-meta {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 20px;
    }
    .main-lead .opn-meta span i {
        color: var(--highlight-color);
        margin-right: 5px;
    }
    .main-lead .opn-lead-image {
        width: 100%;
        height: 550px;
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 25px;
        box-shadow: var(--shadow-sm);
    }
    .main-lead .opn-lead-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .main-lead .opn-lead-image:hover img {
        transform: scale(1.03);
    }
    .main-lead .opn-lead-excerpt {
        font-size: 1.3rem;
        color: var(--text-light);
        line-height: 1.6;
        max-width: 1000px;
        margin: 0 auto;
    }

    /* TRENDING GRID */
    .trending-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
