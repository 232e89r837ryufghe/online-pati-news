---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCategories, getPostsByCategorySlug } from '../lib/cms';

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((cat: any) => ({
    params: { category: decodeURIComponent(cat.slug) },
    props: { categoryName: cat.name, slug: cat.slug },
  }));
}

const { categoryName, slug } = Astro.props;
const results = await getPostsByCategorySlug(slug, 20);
---

<Layout title={`${categoryName} - Online Pati News`}>
  <TopBar />
  <Navbar />
  
  <main class="category-page-wrapper">
    <div class="container cat-container">
      <div class="breadcrumbs">
        <a href="/"><i class="fas fa-home"></i> गृहपृष्ठ</a> 
        <i class="fas fa-chevron-right sep"></i> 
        <span class="curr">{categoryName}</span>
      </div>

      <header class="category-hero-p">
        <div class="cat-label">विधा:</div>
        <h1 class="category-title-p">{categoryName}</h1>
        <div class="category-stats-p">कुल {results.length} समाचार फेला परेका छन्</div>
      </header>

      <div class="opn-layout">
        <div class="opn-main-column">
          {results.length > 0 ? (
            <div class="premium-cat-list">
              {results.map((item) => (
                <article class="cat-result-card-p">
                  <a href={`/news/${item.slug || item.id}`} class="cat-card-inner-p">
                    {item.image && (
                      <div class="cat-card-image-p">
                        <img src={item.image} alt={item.title} />
                        <div class="cat-overlay-p">
                          <span class="time-p"><i class="far fa-clock"></i> {item.date}</span>
                        </div>
                      </div>
                    )}
                    <div class="cat-card-content-p">
                      <h2 class="cat-card-title-p" set:html={item.title}></h2>
                      <p class="cat-card-excerpt-p" set:html={item.excerpt}></p>
                      <div class="cat-card-footer-p">
                        <span class="cat-author-p"><i class="far fa-user"></i> {item.author}</span>
                        <span class="read-more-p">थप पढ्नुहोस् <i class="fas fa-arrow-right"></i></span>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-no-results">
              <div class="no-res-icon"><i class="fas fa-newspaper"></i></div>
              <h3>समाचार फेला परेन</h3>
              <p>माफ गर्नुहोस्, यस विधामा अहिले कुनै समाचार उपलब्ध छैन। हाम्रा अन्य विधाहरू हेर्नुहोस्।</p>
              <a href="/" class="p-btn-back">मुख्य पृष्ठमा फर्कनुहोस्</a>
            </div>
          )}
        </div>

        <Sidebar />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .category-page-wrapper { background-color: var(--bg-white); padding: 20px 0 60px; }
  
  .category-hero-p { background: var(--bg-gray); padding: 50px 40px; border-radius: var(--radius); border-left: 6px solid var(--primary-color); margin-bottom: 40px; position: relative; overflow: hidden; }
  .category-hero-p::after { content: '\f1ea'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; right: -20px; bottom: -20px; font-size: 10rem; color: rgba(0,0,0,0.03); transform: rotate(-15deg); }
  
  .cat-label { font-size: 1rem; color: var(--highlight-color); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
  .category-title-p { font-family: var(--font-headline); font-size: 3.5rem; line-height: 1; color: var(--text-dark); margin-bottom: 10px; }
  .category-stats-p { font-size: 1.1rem; color: var(--text-muted); }

  /* Premium Category List */
  .premium-cat-list { display: flex; flex-direction: column; gap: 30px; }
  
  .cat-result-card-p { background: #fff; border-radius: var(--radius); border: 1px solid var(--border-color); overflow: hidden; transition: 0.3s; box-shadow: var(--shadow-sm); }
  .cat-result-card-p:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
  
  .cat-card-inner-p { display: grid; grid-template-columns: 280px 1fr; text-decoration: none; color: inherit; }
  
  .cat-card-image-p { position: relative; height: 100%; overflow: hidden; }
  .cat-card-image-p img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
  .cat-result-card-p:hover .cat-card-image-p img { transform: scale(1.05); }
  
  .cat-overlay-p { position: absolute; bottom: 0; left: 0; width: 100%; background: linear-gradient(transparent, rgba(0,0,0,0.7)); padding: 15px; color: #fff; font-size: 0.85rem; }

  .cat-card-content-p { padding: 25px; display: flex; flex-direction: column; }
  .cat-card-title-p { font-family: var(--font-headline); font-size: 1.8rem; line-height: 1.25; color: var(--text-main); margin-bottom: 15px; transition: 0.2s; }
  .cat-result-card-p:hover .cat-card-title-p { color: var(--primary-color); }
  
  .cat-card-excerpt-p { font-size: 1.1rem; line-height: 1.6; color: var(--text-light); margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  
  .cat-card-footer-p { margin-top: auto; padding-top: 15px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; color: var(--text-muted); }
  .cat-author-p i, .read-more-p i { color: var(--highlight-color); margin: 0 5px; }
  .read-more-p { font-weight: 700; color: var(--primary-color); }

  /* Premium No Results */
  .p-no-results { padding: 80px 40px; text-align: center; background: var(--bg-gray); border-radius: var(--radius); border: 2px dashed var(--border-color); }
  .no-res-icon { font-size: 4rem; color: var(--border-color); margin-bottom: 20px; }
  .p-no-results h3 { font-family: var(--font-headline); font-size: 2.2rem; color: var(--text-dark); margin-bottom: 15px; }
  .p-no-results p { font-size: 1.2rem; color: var(--text-light); margin-bottom: 30px; }
  .p-btn-back { display: inline-block; background: var(--primary-color); color: #fff; padding: 12px 30px; border-radius: 30px; font-weight: 700; text-decoration: none; transition: 0.3s; }
  .p-btn-back:hover { background: var(--primary-dark); transform: scale(1.05); }

  @media (max-width: 992px) {
    .cat-card-inner-p { grid-template-columns: 220px 1fr; }
    .category-title-p { font-size: 2.5rem; }
  }
  @media (max-width: 768px) {
    .cat-card-inner-p { grid-template-columns: 1fr; }
    .cat-card-image-p { height: 200px; }
    .category-hero-p { padding: 30px 20px; }
    .category-title-p { font-size: 2.2rem; }
  }
</style>
