---
---
<header class="header"> 
    <div class="container header-inner"> 
        <div class="logo"> 
            <a href="/"> 
                <img src="/logo-main.png" alt="Online Pati News" class="header-logo-img" />
            </a> 
        </div> 
        
        <div class="ad-container" style="margin: 0; max-width: 728px;"> 
            <span class="ad-label">Advertisement</span>
            <a href="/advertise" class="ad-slot ad-728x90"> 
                <img src="https://images.unsplash.com/photo-1542744094-13e00b848529?auto=format&fit=crop&q=80&w=728&h=90" alt="Corporate Ad"> 
            </a> 
        </div> 
    </div> 
</header> 

<style is:global>
    .header { background-color: var(--bg-white); padding: 15px 0; border-bottom: 1px solid var(--border-color); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
    .header-logo-img { height: 75px; width: auto; object-fit: contain; }

    @media (max-width: 768px) {
        .header-inner { flex-direction: column; text-align: center; }
        .header-logo-img { height: 50px; }
    }
</style>
