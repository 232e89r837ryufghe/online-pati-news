---
// Static fallback data for the initial render (April 2026)
const staticFallback = [
    { symbol: "NEPSE", value: "2802.52", change: "+45.12", trend: "up" },
    { symbol: "Sensitive", value: "476.88", change: "+5.75", trend: "up" },
    { symbol: "Banking", value: "1468.72", change: "+16.89", trend: "up" },
    { symbol: "Hydropower", value: "3907.16", change: "+99.52", trend: "up" }
];
---

<div class="ticker-wrapper">
    <div class="ticker-label"> <i class="fas fa-chart-line"></i> NEPSE</div>
    <div class="ticker-scroll">
        <ul class="ticker-list" id="tickerList">
            <!-- Initial static load -->
            {staticFallback.map((item) => (
                <li class={`ticker-item ${item.trend}`} data-ticker-symbol={item.symbol}>
                    <span class="symbol">{item.symbol}:</span>
                    <span class="value">{item.value}</span>
                    <span class="change">({item.change})</span>
                </li>
            ))}
            <!-- Duplicate for infinite scroll -->
            {staticFallback.map((item) => (
                <li class={`ticker-item ${item.trend}`} data-ticker-symbol={item.symbol}>
                    <span class="symbol">{item.symbol}:</span>
                    <span class="value">{item.value}</span>
                    <span class="change">({item.change})</span>
                </li>
            ))}
        </ul>
    </div>
</div>

<style>
    .ticker-wrapper {
        background: #1e293b;
        color: #fff;
        height: 38px;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-bottom: 2px solid var(--highlight-color);
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
    }

    .ticker-label {
        background: var(--highlight-color);
        padding: 0 15px;
        height: 100%;
        display: flex;
        align-items: center;
        font-weight: 700;
        z-index: 2;
        box-shadow: 5px 0 10px rgba(0,0,0,0.2);
    }

    .ticker-label i { margin-right: 8px; }

    .ticker-scroll {
        flex: 1;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    .ticker-list {
        display: flex;
        list-style: none;
        padding: 0;
        margin: 0;
        white-space: nowrap;
        animation: ticker 80s linear infinite;
    }

    .ticker-item {
        display: inline-flex;
        align-items: center;
        padding: 0 25px;
        border-right: 1px solid rgba(255,255,255,0.1);
    }

    .ticker-item .symbol { color: #94a3b8; margin-right: 8px; font-weight: 600; text-transform: uppercase; }
    .ticker-item .value { font-weight: 700; margin-right: 6px; }
    .ticker-item .change { font-size: 0.8rem; }

    /* Trends */
    .ticker-item.up .value, .ticker-item.up .change { color: #4ade80; }
    .ticker-item.down .value, .ticker-item.down .change { color: #f87171; }
    .ticker-item.neutral .value, .ticker-item.neutral .change { color: #cbd5e1; }

    @keyframes ticker {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    .ticker-scroll:hover .ticker-list {
        animation-play-state: paused;
    }

    @media (max-width: 768px) {
        .ticker-label { font-size: 0.75rem; padding: 0 10px; }
        .ticker-wrapper { height: 32px; font-size: 0.75rem; }
    }
</style>

<script is:inline>
    // Client-side dynamic NEPSE fetch
    async function updateTicker() {
        try {
            // Using a CORS-friendly public proxy or the real market API if allowed
            // This endpoint is commonly used for community widgets
            const response = await fetch('https://nepsealpha.com/api/indices', {
                method: 'GET',
                mode: 'cors'
            });

            if (response.ok) {
                const data = await response.json();
                // Map the data to our format
                // Example data structure from common public endpoints
                const mappedData = data.map(item => ({
                    symbol: item.index || item.symbol,
                    value: item.current || item.last_price,
                    change: (item.change > 0 ? '+' : '') + item.change,
                    trend: item.change > 0 ? 'up' : (item.change < 0 ? 'down' : 'neutral')
                })).slice(0, 10); // Take first 10 major indices

                if (mappedData.length > 0) {
                    const list = document.getElementById('tickerList');
                    if (list) {
                        // Create the inner HTML for the ticker
                        const itemsHtml = mappedData.map(item => `
                            <li class="ticker-item ${item.trend}">
                                <span class="symbol">${item.symbol}:</span>
                                <span class="value">${item.value}</span>
                                <span class="change">(${item.change})</span>
                            </li>
                        `).join('');
                        
                        // Update with double set for infinite scroll
                        list.innerHTML = itemsHtml + itemsHtml;
                    }
                }
            }
        } catch (e) {
            console.error("Client-side Ticker Fetch Error:", e);
        }
    }

    // Run on load
    window.addEventListener('DOMContentLoaded', () => {
        // Delay slightly for smoother initial load
        setTimeout(updateTicker, 2000);
        // Refresh every 5 minutes
        setInterval(updateTicker, 300000);
    });
</script>
