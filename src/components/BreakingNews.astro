---
import { getPosts, getPostsByCategorySlug } from '../lib/cms';

let breakingPosts = await getPostsByCategorySlug("ब्रेकिङ", 5);
if (breakingPosts.length === 0) {
  breakingPosts = await getPosts(5);
}
---

<div class="breaking-news"> 
    <div class="container breaking-news-inner"> 
        <div class="breaking-label"> 
            <img src="/logo.png" alt="Icon" class="breaking-logo-img" />
            ब्रेकिङ <i class="fas fa-bolt flash"></i> 
        </div> 
        <div class="ticker-wrapper"> 
            <div class="ticker"> 
                {breakingPosts.map((news) => (
                  <div class="ticker-item">
                    <a href={`/news/${news.slug || news.id}`} set:html={news.title}></a>
                  </div>
                ))}
            </div> 
        </div> 
        <div class="quick-links">
            <a href="#"><i class="fas fa-chart-line"></i> शेयर बजार</a>
            <a href="#"><i class="fas fa-coins"></i> सुनचाँदी</a>
            <a href="#"><i class="fas fa-star"></i> राशिफल</a>
            <a href="#"><i class="fas fa-cloud-sun"></i> मौसम</a>
        </div>
    </div> 
</div> 

<style is:global>
    .breaking-news { background: var(--bg-white); border-bottom: 1px solid var(--border-color); padding: 10px 0; margin-bottom: 10px; }
    .breaking-news-inner { display: flex; align-items: center; gap: 15px; }
    .breaking-label { background: var(--highlight-color); color: #fff; padding: 4px 15px; font-weight: 600; font-family: var(--font-headline); font-size: 1.2rem; border-radius: 3px; display: flex; align-items: center; gap: 8px; white-space: nowrap; }
    .breaking-logo-img { height: 18px; width: auto; background: #fff; padding: 2px; border-radius: 2px; }
    .flash { animation: flash 1.5s infinite; color: #fff;}
    @keyframes flash { 50% { opacity: 0; } }
    .ticker-wrapper { overflow: hidden; flex-grow: 1; border-right: 1px solid var(--border-color); padding-right: 15px; }
    .ticker { display: flex; gap: 40px; animation: ticker 25s linear infinite; white-space: nowrap; }
    .ticker-item a { font-weight: 500; color: var(--text-dark); font-size: 1.05rem; }
    .ticker-item a:hover { color: var(--primary-color); }
    @keyframes ticker { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
    .quick-links { display: flex; gap: 15px; white-space: nowrap; padding-left: 5px; }
    .quick-links a { font-size: 0.95rem; font-weight: 600; color: var(--primary-color); display: flex; align-items: center; gap: 5px; background: var(--bg-gray); padding: 4px 10px; border-radius: 4px; border: 1px solid var(--border-color); }
    .quick-links a:hover { color: #fff; background: var(--primary-color); border-color: var(--primary-color); }

    @media (max-width: 768px) {
        .quick-links { display: none; }
        .ticker-wrapper { border-right: none; padding-right: 0; }
    }
</style>
