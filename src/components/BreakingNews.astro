---
import { getWordPressPosts, getWordPressPostsByCategorySlug } from '../lib/wordpress';

let latestPosts = await getWordPressPostsByCategorySlug("ब्रेकिङ", 10);
if (latestPosts.length === 0) {
  latestPosts = await getWordPressPosts(10);
}


const breakingNews = latestPosts.map(post => ({
  title: post.title,
  slug: post.slug || post.id.toString()
}));
---



<div class="breaking-news">
  <div class="container breaking-news-inner">
    <div class="breaking-label">
      ब्रेकिङ <i class="fas fa-bolt flash"></i>
    </div>
    <div class="ticker-wrapper">
      <div class="ticker">
        {breakingNews.map((news) => (
          <div class="ticker-item"><a href={`/news/${news.slug}`} set:html={news.title}></a></div>
        ))}
        {/* Duplicate for seamless scrolling */}
        {breakingNews.map((news) => (
          <div class="ticker-item"><a href={`/news/${news.slug}`} set:html={news.title}></a></div>
        ))}

      </div>
    </div>
  </div>
</div>

<style>
  .breaking-news {
    background-color: #fff;
    border-bottom: 1px solid #eee;
    padding: 0.5rem 0;
    overflow: hidden;
  }

  .breaking-news-inner {
    display: flex;
    align-items: center;
  }

  .breaking-label {
    background-color: var(--primary-color);
    color: white;
    padding: 0.3rem 0.8rem;
    font-family: var(--font-headline);
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    position: relative;
    z-index: 10;
    border-radius: 4px;
    margin-right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .label-logo {
    height: 14px;
    width: auto;
    border-radius: 1px;
    filter: brightness(1);
    background: #fff;
    padding: 1px;
  }

  .flash {
    animation: flash-anim 1s infinite alternate;
  }

  @keyframes flash-anim {
    from { opacity: 0.5; }
    to { opacity: 1; }
  }

  .ticker-wrapper {
    flex-grow: 1;
    overflow: hidden;
    position: relative;
  }

  .ticker {
    display: flex;
    white-space: nowrap;
    animation: scroll-ticker 30s linear infinite;
  }

  .ticker:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    padding: 0 1.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-color);
  }

  .ticker-item a:hover {
    color: var(--primary-color);
  }

  @keyframes scroll-ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .breaking-label {
      padding: 0.2rem 0.5rem;
      font-size: 0.8rem;
      margin-right: 0.5rem;
    }
    .ticker-item {
      padding: 0 0.8rem;
      font-size: 0.9rem;
    }
  }
</style>
