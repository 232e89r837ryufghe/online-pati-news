---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
    <div class="container">
        <!-- ROW 1: BRAND + 5 COLUMN LINKS GRID -->
        <div class="footer-top-grid">
            <!-- Column 1: Brand -->
            <div class="footer-brand">
                <a
                    href="/"
                    style="display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: 25px;"
                >
                    <img
                        src="/logo.png"
                        alt="Logo"
                        class="footer-logo-img"
                        style="margin-bottom: 0; height: 45px; padding: 5px 10px;"
                    />
                    <span
                        class="footer-brand-text"
                        style="font-family: var(--font-headline); font-size: 1.4rem; color: #fff; font-weight: 700; line-height: 1;"
                        >Online Pati News</span
                    >
                </a>
                <p class="brand-desc">
                    अनलाइन पाटी न्युज - नेपालको अग्रणी डिजिटल समाचार पोर्टल,
                    तपाईंको स्क्रिनसम्म छिटो, सत्य र निष्पक्ष समाचार पुर्‍याउन
                    प्रतिबद्ध छ।
                </p>
                <div class="social-links-row">
                    <a href="#" aria-label="Facebook"
                        ><i class="bi bi-facebook"></i></a
                    >
                    <a href="#" aria-label="Twitter"
                        ><i class="bi bi-twitter-x"></i></a
                    >
                    <a href="#" aria-label="YouTube"
                        ><i class="bi bi-youtube"></i></a
                    >
                    <a href="#" aria-label="Instagram"
                        ><i class="bi bi-instagram"></i></a
                    >
                    <a href="#" aria-label="TikTok"
                        ><i class="bi bi-tiktok"></i></a
                    >
                    <a href="#" aria-label="WhatsApp"
                        ><i class="bi bi-whatsapp"></i></a
                    >
                    <a href="#" aria-label="Messenger"
                        ><i class="bi bi-messenger"></i></a
                    >
                </div>
            </div>

            <!-- Column 2: Categories -->
            <div class="footer-col">
                <h3>समाचार विधा</h3>
                <ul>
                    <li><a href="/राजनीति">राजनीति</a></li>
                    <li><a href="/अर्थतन्त्र">अर्थतन्त्र</a></li>
                    <li><a href="/खेलकुद">खेलकुद</a></li>
                    <li><a href="/मनोरञ्जन">मनोरञ्जन</a></li>
                    <li><a href="/स्वास्थ्य">स्वास्थ्य</a></li>
                    <li><a href="/सूचना-प्रविधि">सूचना प्रविधि</a></li>
                </ul>
            </div>

            <!-- Column 3: Provinces -->
            <div class="footer-col">
                <h3>प्रदेश समाचार</h3>
                <ul>
                    <li><a href="#">कोशी प्रदेश</a></li>
                    <li><a href="#">मधेश प्रदेश</a></li>
                    <li><a href="#">बागमती प्रदेश</a></li>
                    <li><a href="#">गण्डकी प्रदेश</a></li>
                    <li><a href="#">लुम्बिनी प्रदेश</a></li>
                    <li><a href="#">कर्णाली / सुदुरपश्चिम</a></li>
                </ul>
            </div>

            <!-- Column 4: About & Our Portal -->
            <div class="footer-col">
                <h3>हाम्रो बारेमा</h3>
                <ul>
                    <li><a href="/about">हाम्रो बारेमा</a></li>
                    <li><a href="/contact">सम्पर्क / विज्ञापन</a></li>
                    <li><a href="/team">हाम्रो टोली</a></li>
                    <li><a href="/career">हाम्रो कार्यालय</a></li>
                    <li><a href="/subscribe">सदस्यता</a></li>
                </ul>
            </div>

            <!-- Column 5: Legal & Policy -->
            <div class="footer-col">
                <h3>नीति तथा नियम</h3>
                <ul>
                    <li><a href="/privacy">गोपनीयता नीति</a></li>
                    <li><a href="/terms">नियम तथा शर्त</a></li>
                    <li><a href="/editorial">सम्पादकीय नीति</a></li>
                    <li><a href="/faq">बारम्बार सोधिने प्रश्न</a></li>
                    <li><a href="/cookie">कुकी नीति</a></li>
                </ul>
            </div>
        </div>

        <hr class="footer-divider" />

        <!-- ROW 2: EDITORIAL & REGISTRATIONS -->
        <div class="footer-middle-grid">
            <div class="editorial-info">
                <div class="ed-item">
                    <span class="label"
                        ><i class="bi bi-person-badge"></i> अध्यक्ष / प्रबन्ध निर्देशक
                        :</span
                    >
                    <span class="value">राजेन्द्र बिमली</span>
                </div>
                <div class="ed-item">
                    <span class="label"
                        ><i class="bi bi-person-workspace"></i> प्रधान सम्पादक :</span
                    >
                    <span class="value">[सम्पादकको नाम]</span>
                </div>
            </div>

            <div class="registration-info">
                <p>
                    <i class="bi bi-card-checklist"></i> सूचना विभाग दर्ता नं. : <strong
                        >[००००/०७७-७८]</strong>
                </p>
                <p>
                    <i class="bi bi-patch-check"></i> प्रेस काउन्सिल सूचीकरण नं. :
                    <strong>[००००]</strong>
                </p>
            </div>

            <div class="app-section">
                <p class="label">मोबाइल एप डाउनलाेड गर्नुहोस्</p>
                <div class="app-btns">
                    <a href="#" class="app-btn"
                        ><i class="bi bi-google-play"></i> Google Play</a
                    >
                    <a href="#" class="app-btn"
                        ><i class="bi bi-apple"></i> App Store</a
                    >
                </div>
            </div>
        </div>

        <hr class="footer-divider" />

        <!-- ROW 3: CONTACT & FOOTER BOTTOM -->
        <div class="footer-bottom-info">
            <div class="contact-details">
                <p><i class="bi bi-geo-alt"></i> पुतलीसडक, काठमाडौँ, नेपाल</p>
                <p><i class="bi bi-telephone"></i> +9779765484188</p>
                <p><i class="bi bi-envelope"></i> onlinepatinews@gmail.com</p>
            </div>
            <div class="copyright-row">
                <p>© 2026 Online Pati News Pvt. Ltd. | सर्वाधिकार सुरक्षित।</p>
            </div>
        </div>
    </div>
</footer>

<style is:global>
    .footer {
        background-color: #0f172a;
        color: #94a3b8;
        padding: 100px 0 30px;
        border-top: 6px solid var(--highlight-color);
    }

    /* TOP GRID - 5 COLUMNS */
    .footer-top-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 50px;
    }

    .footer-brand .footer-logo-img {
        height: 75px;
        margin-bottom: 25px;
        padding: 10px 20px;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
    .brand-desc {
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 30px;
        color: #cbd5e1;
    }

    .social-links-row {
        display: flex;
        gap: 12px;
    }
    .social-links-row a {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        transition: 0.3s;
    }
    .social-links-row a:hover {
        background: var(--highlight-color);
        color: #fff;
        transform: translateY(-5px);
    }

    .footer-col h3 {
        font-family: var(--font-headline);
        color: #f1f5f9;
        font-size: 1.6rem;
        margin-bottom: 25px;
        position: relative;
        padding-bottom: 12px;
        font-weight: 700;
    }
    .footer-col h3::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 40px;
        height: 3px;
        background: var(--highlight-color);
    }

    .footer-col ul li {
        margin-bottom: 15px;
        font-size: 1.1rem;
        list-style: none;
    }
    .footer-col ul li a {
        color: #94a3b8;
        transition: 0.3s;
        display: block;
        text-decoration: none;
    }
    .footer-col ul li a:hover {
        color: #fff;
        transform: translateX(5px);
    }

    /* MIDDLE GRID */
    .footer-divider {
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        margin: 40px 0;
    }

    .footer-middle-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: 40px;
        align-items: center;
    }
    .editorial-info {
        display: flex;
        gap: 40px;
    }
    .ed-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    .ed-item .label {
        font-size: 0.9rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .ed-item .value {
        font-family: var(--font-headline);
        color: #f1f5f9;
        font-size: 1.6rem;
        font-weight: 600;
    }

    .registration-info {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #94a3b8;
    }
    .registration-info strong {
        color: #f1f5f9;
    }

    .app-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: flex-end;
    }
    .app-section .label {
        font-size: 0.9rem;
        color: #64748b;
    }
    .app-btns {
        display: flex;
        gap: 12px;
    }
    .app-btn {
        padding: 10px 16px;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 6px;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        text-decoration: none;
    }
    .app-btn:hover {
        background: #334155;
        border-color: var(--highlight-color);
        color: var(--highlight-color);
    }

    /* BOTTOM ROW */
    .footer-bottom-info {
        text-align: center;
    }
    .contact-details {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 40px;
        flex-wrap: wrap;
        margin-bottom: 30px;
        font-size: 1.1rem;
        color: #cbd5e1;
    }
    .contact-details i {
        color: var(--highlight-color);
        margin-right: 8px;
    }

    .copyright-row {
        display: flex;
        justify-content: center;
        align-items: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 25px;
        font-size: 1rem;
        color: #64748b;
        text-align: center;
    }

    /* RESPONSIVE */
    @media (max-width: 1200px) {
        .footer-top-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
        }
    }
    @media (max-width: 768px) {
        .footer {
            padding: 60px 0 30px;
        }
        .footer-top-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 35px;
        }
        .footer-brand {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .footer-brand .footer-logo-img {
            height: 60px;
            padding: 8px 15px;
        }
        .social-links-row {
            justify-content: center;
        }

        .footer-col h3 {
            font-size: 1.4rem;
            margin-bottom: 20px;
        }
        .footer-col h3::after {
            left: 50%;
            transform: translateX(-50%);
        }
        .footer-col ul li a:hover {
            transform: translateX(0);
            color: var(--highlight-color);
        }

        .footer-middle-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 30px;
        }
        .editorial-info {
            flex-direction: column;
            gap: 20px;
            align-items: center;
        }
        .ed-item .value {
            font-size: 1.4rem;
        }

        .registration-info {
            line-height: 2;
        }
        .app-section {
            align-items: center;
        }

        .contact-details {
            flex-direction: column;
            gap: 15px;
            margin-bottom: 25px;
        }
        .copyright-row {
            flex-direction: column;
            gap: 10px;
            padding: 20px 15px 0;
        }
    }
</style>
