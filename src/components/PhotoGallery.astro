---
import { getWordPressPosts } from '../lib/wordpress';

const posts = await getWordPressPosts(4);
const galleryItems = posts.map(post => ({
  id: post.id,
  slug: post.slug,
  image: post.image,
  title: post.title,
  category: post.category
}));
---

<section class="photo-gallery">
  <div class="container gallery-inner">
    <div class="section-header">
      <h2 class="section-title">फोटो फिचर (Multimedia)</h2>
      <a href="/gallery" class="view-all">सबै फोटोहरू <i class="fas fa-camera"></i></a>
    </div>

    <div class="gallery-grid">
      <div class="featured-item">
        <div class="image-wrapper">
          <img src={galleryItems[0].image} alt={galleryItems[0].title} />
          <div class="overlay">
            <span class="category">{galleryItems[0].category}</span>
            <h3>{galleryItems[0].title}</h3>
          </div>
        </div>
      </div>
      <div class="secondary-items">
        {galleryItems.slice(1).map((item) => (
          <div class="gallery-item">
            <div class="image-wrapper">
              <img src={item.image} alt={item.title} />
              <div class="overlay-small">
                <span class="category">{item.category}</span>
                <h3>{item.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .photo-gallery {
    background-color: #111827; /* Deep professional slate instead of harsh black */
    color: white;
    padding: 4rem 0;
    margin: 3rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-title {
    font-family: var(--font-headline);
    font-size: 2rem;
  }

  .section-title::after {
    background-color: #fff;
  }

  .view-all {
    color: #fff;
    opacity: 0.8;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .view-all:hover {
    opacity: 1;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1.5rem;
    height: 550px;
  }

  .secondary-items {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 6px;
    cursor: pointer;
    background-color: #1f2937; /* Placeholder color before image loads */
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .image-wrapper:hover img {
    transform: scale(1.05);
  }

  .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .overlay-small {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 70%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .overlay h3 { font-size: 2rem; margin-bottom: 0.5rem; font-family: var(--font-headline); line-height: 1.2; }
  .overlay-small h3 { font-size: 1.1rem; font-family: var(--font-headline); line-height: 1.3; }

  .category {
    background: var(--primary-color);
    padding: 2px 10px;
    font-size: 0.8rem;
    align-self: flex-start;
    margin-bottom: 0.8rem;
    border-radius: 2px;
    font-weight: bold;
    text-transform: uppercase;
  }

  .overlay-small .category {
    padding: 2px 8px;
    font-size: 0.7rem;
    margin-bottom: 0.4rem;
  }

  @media (max-width: 992px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      height: auto;
    }
    .featured-item {
      height: 400px;
    }
    .secondary-items {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      grid-template-rows: auto;
      height: auto;
    }
    .gallery-item {
      height: 200px;
    }
  }
</style>
