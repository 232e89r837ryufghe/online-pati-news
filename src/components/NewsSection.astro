---
interface NewsItem {
  id: number;
  slug?: string;
  title: string;
  image: string;
  excerpt?: string;
  date?: string;
  dateIso?: string;
  author?: string;
}

interface Props {
  title: string;
  link: string;
  news: NewsItem[];
  layout?: 'grid' | 'list' | 'featured';
}

const { title, link, news, layout = 'grid' } = Astro.props;
import { getRelativeTimeNepali } from '../utils/date';
---

<section class="news-category">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title"><a href={link}>{title}</a></h2>
      <a href={link} class="view-all">थप हेर्नुहोस् <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class={`news-content ${layout}`}>
      {news.map((item, index) => (
        <a href={`/news/${item.slug || item.id}`} class="news-card">
          {item.image && (
            <div class="image-wrapper">
              <img src={item.image} alt={item.title} />
            </div>
          )}
          <div class="content">
            <h3 set:html={item.title}></h3>
            {layout === 'featured' && index === 0 && <p>{item.excerpt}</p>}
            <div class="card-meta">
              <span class="meta-item">
                <i class="bi bi-clock"></i> {getRelativeTimeNepali(item.dateIso || '')}
              </span>
              {(layout === 'featured' || layout === 'grid') && (
                <span class="meta-item">
                  <img src="/logo.png" alt="Logo" class="mini-logo" /> {item.author || 'अनलाइनपाटी न्युज'}
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


<style>
  .news-category {
    padding: 2rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    margin-bottom: 0;
    font-size: 1.8rem;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background-color: var(--primary-color);
  }

  .view-all {
    color: var(--primary-color);
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-headline);
  }

  .news-content.grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .news-content.featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .news-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  .news-card:hover h3 {
    color: var(--primary-color);
  }

  .image-wrapper {
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 0.8rem;
    aspect-ratio: 16 / 9;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .news-card:hover img {
    transform: scale(1.05);
  }

  h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 600;
    font-family: var(--font-headline);
    margin-bottom: 0.5rem;
  }

  p {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-content.list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .list .news-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .list .image-wrapper {
    width: 100px;
    height: 70px;
    flex-shrink: 0;
    margin-bottom: 0;
  }

  .list h3 {
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  @media (max-width: 768px) {
    .news-content.featured {
      grid-template-columns: 1fr;
    }
  }
</style>
