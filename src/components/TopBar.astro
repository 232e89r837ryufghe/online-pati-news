---
import * as NepaliDateLib from 'nepali-date-converter';

const today = new Date();

// High-compatibility import pattern for SSR environments
const NepaliDate = (NepaliDateLib as any).default?.default || (NepaliDateLib as any).default || NepaliDateLib;

// Convert to Nepali Date (B.S.)
const npDate = new NepaliDate(today);
const nepaliDays = ["आइतबार", "सोमबार", "मंगलबार", "बुधबार", "बिहीबार", "शुक्रबार", "शनिबार"];

// Formatting: Weekday, Day Month Year (B.S.)
const bsFormatted = `${nepaliDays[today.getDay()]}, ${npDate.format('DD MMMM YYYY', 'np')}`;
const englishDate = today.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="top-bar"> 
    <div class="container top-bar-inner"> 
        <div class="date-info"> 
            <span class="nepali-date"><i class="far fa-calendar-alt"></i> {bsFormatted}</span> 
            <span class="divider">|</span> 
            <span class="live-clock"><i class="far fa-clock"></i> <span id="clockDisplay"></span></span> 
            <span class="divider english-hide">|</span> 
            <span class="english-date english-hide">{englishDate}</span> 
        </div> 
        
        <div class="top-bar-right">
            <div class="social-links"> 
                <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a> 
                <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a> 
                <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a> 
                <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"></i></a> 
            </div> 
        </div>
    </div> 
</div>  

<script is:inline>
    // Clock Feature
    function updateClock() {
        const now = new Date();
        const display = now.toLocaleTimeString('ne-NP', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const clockEl = document.getElementById('clockDisplay');
        if (clockEl) clockEl.textContent = display;
    }
    setInterval(updateClock, 1000);
    updateClock();
</script>

<style is:global>
    .top-bar { background-color: #0f172a; color: #fff; font-size: 0.9rem; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .top-bar-inner { display: flex; justify-content: space-between; align-items: center; }
    .date-info { display: flex; align-items: center; gap: 12px; }
    .date-info i { color: var(--highlight-color); }
    .divider { color: #334155; }
    
    .top-bar-right { display: flex; align-items: center; gap: 20px; }
    
    .social-links a { color: #cbd5e1; margin-left: 15px; font-size: 1rem; transition: 0.3s; }
    .social-links a:hover { color: var(--highlight-color); }
    
    .live-clock { font-weight: 600; min-width: 85px; }

    @media (max-width: 992px) {
        .english-hide { display: none; }
    }
    @media (max-width: 768px) {
        .top-bar-inner { flex-direction: column; gap: 8px; text-align: center; }
        .top-bar-right { flex-direction: column; gap: 10px; }
        .social-links a { margin: 0 10px; }
    }
</style>
