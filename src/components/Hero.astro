---
import { getWordPressPosts } from '../lib/wordpress';

const allPosts = await getWordPressPosts(5);
const mainNews = allPosts[0] || { id: 0, slug: '', title: 'समाचार फेला परेन', image: '', category: 'समाचार', excerpt: '', author: 'अनलाइन पाटी', date: '' };
const secondaryMain = allPosts[1];
const sideNews = allPosts.slice(2, 5);
---

<section class="hero-section">
  <div class="container">
    <!-- 1. Main Headline Block (Onlinekhabar Style for newest post) -->
    <div class="main-headline-block">
      <div class="category-tag-wrapper">
        <span class="category-tag main-tag">{mainNews.category}</span>
      </div>
      <a href={`/news/${mainNews.slug || mainNews.id}`} class="main-title-link">
        <h1 class="main-hero-title">{mainNews.title}</h1>
      </a>
      <div class="main-hero-meta">
        <span class="author"><i class="far fa-user"></i> {mainNews.author}</span>
        <span class="date"><i class="far fa-calendar-alt"></i> {mainNews.date}</span>
      </div>
      <a href={`/news/${mainNews.slug || mainNews.id}`} class="main-hero-image-link">
        <div class="main-featured-image">
          <img src={mainNews.image} alt={mainNews.title} />
        </div>
      </a>
      <p class="main-hero-excerpt">{mainNews.excerpt}</p>
    </div>

    <!-- 2. Old Layout for remaining posts -->
    {secondaryMain && (
      <div class="hero-grid">
        <div class="main-news">
          <a href={`/news/${secondaryMain.slug || secondaryMain.id}`} class="hero-card main-card">
            <div class="image-wrapper">
              <img src={secondaryMain.image} alt={secondaryMain.title} />
              <div class="category-tag">{secondaryMain.category}</div>
            </div>
            <div class="content">
              <h2>{secondaryMain.title}</h2>
              <p>{secondaryMain.excerpt}</p>
              <div class="meta">
                <span class="author"><i class="far fa-user"></i> {secondaryMain.author}</span>
                <span class="date"><i class="far fa-calendar-alt"></i> {secondaryMain.date}</span>
              </div>
            </div>
          </a>
        </div>
        <div class="sidebar-news">
          {sideNews.map((news) => (
            <a href={`/news/${news.slug || news.id}`} class="hero-card side-card">
              <div class="image-wrapper">
                <img src={news.image} alt={news.title} />
              </div>
              <div class="content">
                <div class="category-tag">{news.category}</div>
                <h3>{news.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero-section {
    padding: 2.5rem 0;
    background: #fff;
  }

  /* 1. Main Headline Block */
  .main-headline-block {
    text-align: center;
    max-width: 1000px;
    margin: 0 auto 3rem;
  }

  .category-tag-wrapper {
    margin-bottom: 1rem;
  }

  .main-tag {
    font-size: 1rem;
    background-color: #e31e24; /* Red accent for main category like Onlinekhabar */
  }

  .main-title-link {
    text-decoration: none;
    color: #1a1a1a;
  }

  .main-hero-title {
    font-size: 4rem; /* Massive headline */
    font-family: var(--font-headline);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }

  .main-hero-title:hover {
    color: var(--primary-color);
  }

  .main-hero-meta {
    font-size: 1rem;
    color: #666;
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
    gap: 2rem;
  }

  .main-hero-meta i {
    color: var(--primary-color);
    margin-right: 0.5rem;
  }

  .main-featured-image {
    width: 100%;
    aspect-ratio: 21 / 9; /* Cinematic wide ratio */
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .main-featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .main-headline-block:hover .main-featured-image img {
    transform: scale(1.02);
  }

  .main-hero-excerpt {
    font-size: 1.3rem;
    color: #444;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  /* 2. Secondary Old Grid */
  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    padding-top: 3rem;
    border-top: 2px solid #f0f0f0;
  }

  .hero-card {
    display: block;
    position: relative;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .hero-card:hover h2, .hero-card:hover h3 {
    color: var(--primary-color);
  }

  .main-card .image-wrapper {
    height: 450px;
  }

  .side-card {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .side-card .image-wrapper {
    width: 120px;
    height: 100px;
    flex-shrink: 0;
  }

  .image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
  }

  .hero-card .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .hero-card:hover .image-wrapper img {
    transform: scale(1.05);
  }

  .category-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    background-color: var(--primary-color);
    color: white;
    padding: 2px 8px;
    font-size: 0.75rem;
    font-family: var(--font-headline);
    border-radius: 2px;
    z-index: 5;
  }

  .main-headline-block .category-tag {
    position: static;
    display: inline-block;
  }

  .side-card .category-tag {
    position: static;
    display: inline-block;
    margin-bottom: 0.3rem;
  }

  .main-card .content {
    padding-top: 1rem;
  }

  .main-card h2 {
    font-size: 2.2rem;
    line-height: 1.2;
    margin-bottom: 0.8rem;
    font-family: var(--font-headline);
  }

  .main-card p {
    color: #666;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .side-card .content {
    flex-grow: 1;
  }

  .side-card h3 {
    font-size: 1.2rem;
    line-height: 1.3;
    font-family: var(--font-headline);
  }

  .meta {
    font-size: 0.85rem;
    color: #888;
    display: flex;
    gap: 1.5rem;
  }

  .meta i {
    margin-right: 0.3rem;
  }

  @media (max-width: 1200px) {
    .main-hero-title { font-size: 3rem; }
  }

  @media (max-width: 992px) {
    .main-hero-title { font-size: 2.5rem; }
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .main-card .image-wrapper {
      height: 300px;
    }
    .main-card h2 {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 768px) {
    .main-hero-title { font-size: 2rem; }
    .main-featured-image { aspect-ratio: 16 / 9; }
  }
</style>
