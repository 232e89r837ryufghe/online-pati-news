---
import { getPosts } from '../lib/cms';

const allPosts = await getPosts(7);
const leadNews = allPosts[0];
const textListNews = allPosts.slice(1, 4);
const subGridNews = allPosts.slice(4, 6);
---

{leadNews && (
<div class="ok-main-column">
  <!-- Lead Story -->
  <div class="ok-lead-story">
    <a href={`/news/${leadNews.slug || leadNews.id}`}>
      <h1 class="ok-lead-title">{leadNews.title}</h1>
    </a>
    <div class="ok-meta">
      <span><i class="far fa-user"></i> {leadNews.author}</span>
      <span><i class="far fa-clock"></i> {leadNews.date}</span>
    </div>
    {leadNews.image && (
      <a href={`/news/${leadNews.slug || leadNews.id}`}>
        <div class="ok-lead-image">
          <img src={leadNews.image} alt={leadNews.title} />
        </div>
      </a>
    )}
    <p class="ok-lead-excerpt">{leadNews.excerpt}</p>
  </div>

  <!-- Text-Only Highlight List -->
  {textListNews.length > 0 && (
    <ul class="ok-text-list">
      {textListNews.map((news) => (
        <li>
          <i class="fas fa-square"></i>
          <a href={`/news/${news.slug || news.id}`} set:html={news.title}></a>
        </li>
      ))}
    </ul>
  )}

  <!-- Sub Grid -->
  {subGridNews.length > 0 && (
    <div class="ok-sub-grid">
      {subGridNews.map((news) => (
        <article class="news-card-standard">
          <a href={`/news/${news.slug || news.id}`}>
            {news.image && (
              <div class="img-wrap">
                <img src={news.image} alt={news.title} />
              </div>
            )}
            <h3>{news.title}</h3>
            <p>{news.excerpt}</p>
          </a>
        </article>
      ))}
    </div>
  )}
</div>
)}

<style is:global>
  /* Lead Story */
  .ok-lead-story { text-align: center; margin-bottom: var(--space-lg); padding: 0 var(--space-sm); }
  .ok-lead-title { 
    font-family: var(--font-headline); 
    font-size: 3.5rem; 
    font-weight: 700; 
    line-height: 1.1; 
    color: var(--text-main); 
    margin-bottom: var(--space-sm); 
    letter-spacing: -0.01em;
  }
  .ok-lead-title:hover { color: var(--primary); }
  .ok-meta { 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    gap: 1.5rem; 
    font-size: 0.95rem; 
    color: var(--text-light); 
    margin-bottom: var(--space-md); 
    font-weight: 600;
  }
  .ok-meta span i { color: var(--primary); margin-right: 6px; }
  .ok-lead-image { 
    width: 100%; 
    height: 600px; 
    border-radius: var(--border-radius); 
    overflow: hidden; 
    margin-bottom: var(--space-md); 
    box-shadow: var(--shadow-lg); 
    position: relative;
  }
  .ok-lead-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1); }
  .ok-lead-image:hover img { transform: scale(1.04); }
  .ok-lead-excerpt { 
    font-size: 1.35rem; 
    color: var(--text-dark); 
    line-height: 1.6; 
    max-width: 850px; 
    margin: 0 auto; 
    font-weight: 400;
  }

  /* Text-Only Highlight List */
  .ok-text-list { 
    display: flex; 
    flex-direction: column; 
    gap: 1.25rem; 
    margin: 0 0 var(--space-lg) 0; 
    padding: var(--space-md) var(--space-lg); 
    background: var(--bg-white); 
    border-radius: var(--border-radius); 
    border-left: 6px solid var(--secondary); 
    list-style: none; 
    box-shadow: var(--shadow-soft);
  }
  .ok-text-list li { display: flex; align-items: flex-start; gap: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; }
  .ok-text-list li:last-child { border-bottom: none; padding-bottom: 0; }
  .ok-text-list li i { color: var(--secondary); font-size: 0.7rem; margin-top: 0.8rem; }
  .ok-text-list li a { 
    font-family: var(--font-headline); 
    font-size: 1.85rem; 
    font-weight: 700; 
    color: var(--text-main); 
    line-height: 1.2; 
    transition: color 0.3s ease;
  }
  .ok-text-list li a:hover { color: var(--primary); }

  /* Sub Grid */
  .ok-sub-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-lg); }
  .news-card-standard .img-wrap { 
    width: 100%; 
    aspect-ratio: 16/9; 
    border-radius: var(--border-radius); 
    overflow: hidden; 
    margin-bottom: 1rem; 
    box-shadow: var(--shadow-sm);
  }
  .news-card-standard .img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .news-card-standard:hover .img-wrap img { transform: scale(1.06); }
  .news-card-standard h3 { 
    font-family: var(--font-headline); 
    font-size: 1.75rem; 
    line-height: 1.2; 
    margin-bottom: 0.75rem; 
    color: var(--text-main); 
    font-weight: 700;
  }
  .news-card-standard:hover h3 { color: var(--primary); }
  .news-card-standard p { font-size: 1.05rem; color: var(--text-light); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .news-card-standard a { text-decoration: none; color: inherit; display: block; }

  @media (max-width: 1024px) {
    .ok-lead-title { font-size: 3.2rem; }
    .ok-lead-image { height: 400px; }
  }
  @media (max-width: 768px) {
    .ok-lead-title { font-size: 2.5rem; }
    .ok-lead-image { height: 250px; }
    .ok-text-list li a { font-size: 1.4rem; }
    .ok-sub-grid { grid-template-columns: 1fr; }
  }
</style>
