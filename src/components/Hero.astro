---
import { getWordPressPosts } from '../lib/wordpress';

const allPosts = await getWordPressPosts(7);
const mainNews = allPosts[0] || { id: 0, slug: '', title: 'समाचार फेला परेन', image: '', category: 'समाचार', excerpt: '', author: 'अनलाइन पाटी', date: '' };
const gridNews = allPosts.slice(1, 3);
const listNews = allPosts.slice(3, 7);
---

<section class="hero-section">
  <div class="container">
    <!-- 1. Main Headline Block (Onlinekhabar Style) -->
    <div class="main-headline-block">
      <div class="category-tag-wrapper">
        <span class="category-tag main-tag">{mainNews.category}</span>
      </div>
      <a href={`/news/${mainNews.slug}`} class="main-title-link">
        <h1 class="main-hero-title">{mainNews.title}</h1>
      </a>
      <div class="main-hero-meta">
        <span class="author"><i class="far fa-user"></i> {mainNews.author}</span>
        <span class="date"><i class="far fa-calendar-alt"></i> {mainNews.date}</span>
      </div>
      <a href={`/news/${mainNews.slug}`} class="main-hero-image-link">
        <div class="main-featured-image">
          <img src={mainNews.image} alt={mainNews.title} />
        </div>
      </a>
      <p class="main-hero-excerpt">{mainNews.excerpt}</p>
    </div>

    <!-- 2. Secondary Hybrid Grid -->
    <div class="secondary-news-grid">
      <div class="featured-grid">
        {gridNews.map((news) => (
          <a href={`/news/${news.slug}`} class="secondary-card">
            <div class="image-wrapper">
              <img src={news.image} alt={news.title} />
              <div class="overlay">
                <span class="category-tag">{news.category}</span>
                <h3>{news.title}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      <div class="side-stories-list">
        {listNews.map((news) => (
          <a href={`/news/${news.slug}`} class="side-story-item">
            <div class="thumb-wrapper">
              <img src={news.image} alt={news.title} />
            </div>
            <div class="side-content">
              <h4>{news.title}</h4>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 2.5rem 0;
    background: #fff;
  }

  /* 1. Main Headline Block */
  .main-headline-block {
    text-align: center;
    max-width: 1000px;
    margin: 0 auto 3rem;
  }

  .category-tag-wrapper {
    margin-bottom: 1rem;
  }

  .category-tag {
    background-color: var(--primary-color);
    color: white;
    padding: 4px 12px;
    font-size: 0.85rem;
    font-family: var(--font-headline);
    text-transform: uppercase;
    font-weight: 600;
  }

  .main-tag {
    font-size: 1rem;
    background-color: #e31e24; /* Red accent for main category like Onlinekhabar */
  }

  .main-title-link {
    text-decoration: none;
    color: #1a1a1a;
  }

  .main-hero-title {
    font-size: 4rem; /* Massive headline */
    font-family: var(--font-headline);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }

  .main-hero-title:hover {
    color: var(--primary-color);
  }

  .main-hero-meta {
    font-size: 1rem;
    color: #666;
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
    gap: 2rem;
  }

  .main-hero-meta i {
    color: var(--primary-color);
    margin-right: 0.5rem;
  }

  .main-featured-image {
    width: 100%;
    aspect-ratio: 21 / 9; /* Cinematic wide ratio */
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .main-featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .main-headline-block:hover .main-featured-image img {
    transform: scale(1.02);
  }

  .main-hero-excerpt {
    font-size: 1.3rem;
    color: #444;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  /* 2. Secondary Hybrid Grid */
  .secondary-news-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 2px solid #f0f0f0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .secondary-card {
    display: block;
    text-decoration: none;
    color: white;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .secondary-card .image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .secondary-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .secondary-card .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(transparent, rgba(0,0,0,0.85));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .secondary-card h3 {
    font-size: 1.5rem;
    font-family: var(--font-headline);
    margin-top: 0.5rem;
    line-height: 1.3;
  }

  .secondary-card:hover img {
    transform: scale(1.05);
  }

  /* Side Stories List */
  .side-stories-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .side-story-item {
    display: flex;
    gap: 1rem;
    text-decoration: none;
    color: #333;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .side-story-item:last-child {
    border-bottom: none;
  }

  .thumb-wrapper {
    width: 100px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .thumb-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .side-content h4 {
    font-size: 1.1rem;
    font-family: var(--font-headline);
    line-height: 1.4;
    font-weight: 600;
  }

  .side-story-item:hover h4 {
    color: var(--primary-color);
  }

  @media (max-width: 1200px) {
    .main-hero-title { font-size: 3rem; }
  }

  @media (max-width: 992px) {
    .secondary-news-grid { grid-template-columns: 1fr; }
    .main-hero-title { font-size: 2.5rem; }
  }

  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr; }
    .main-hero-title { font-size: 2rem; }
    .main-featured-image { aspect-ratio: 16 / 9; }
  }
</style>
